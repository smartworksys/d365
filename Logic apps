<!DOCTYPE html>
<html>

<head>
<meta charset="utf-8" />
<title>Policy Non Header Details</title>

<style>

    body {
        font-family: "Segoe UI", Tahoma, Arial, sans-serif;
        background-color: #f3f2f1;
        margin: 0;
        padding: 18px 16px 16px 16px;
        color: #323130;
    }

    .title {
        font-size: 18px;
        font-weight: 600;
        color: #201f1e;
    }

    .page-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        margin-bottom: 14px;
    }

    .print-btn {
        background: #0078d4;
        color: #ffffff;
        border: 1px solid #0078d4;
        padding: 7px 16px;
        font-size: 13px;
        font-family: inherit;
        cursor: pointer;
        border-radius: 2px;
        white-space: nowrap;
    }

    .print-btn:hover:not(:disabled) {
        background: #106ebe;
        border-color: #106ebe;
    }

    .print-btn:disabled {
        background: #c8c6c4;
        border-color: #c8c6c4;
        color: #605e5c;
        cursor: not-allowed;
    }

    .print-only {
        display: none;
    }

    #printReportHeader {
        border-bottom: 2px solid #0078d4;
        margin-bottom: 16px;
        padding-bottom: 12px;
    }

    .print-brand {
        font-size: 20px;
        font-weight: 600;
        color: #201f1e;
        margin-bottom: 10px;
    }

    .print-meta-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 12px;
    }

    .print-meta-table td {
        padding: 3px 12px 3px 0;
        vertical-align: top;
    }

    .print-meta-table td:first-child {
        color: #605e5c;
        width: 120px;
        font-weight: 600;
    }

    .print-meta-table td:last-child {
        color: #201f1e;
    }

    #loader {
        position: fixed;
        inset: 0;
        background: rgba(255,255,255,0.78);
        display: none;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        z-index: 9999;
    }

    .loader-content {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
    }

    .spinner {
        width: 38px;
        height: 38px;
        border: 4px solid #d2d0ce;
        border-top: 4px solid #0078d4;
        border-radius: 50%;
        animation: spin 1s linear infinite;
    }

    .loader-text {
        margin-top: 12px;
        font-size: 13px;
        color: #323130;
        text-align: center;
    }

    @keyframes spin {
        100% { transform: rotate(360deg); }
    }

    .hidden,
    .row.hidden,
    .section.hidden {
        display: none !important;
    }

    #printBtn {
        display: none !important;
    }

    #errorBanner {
        display: none;
        background: #fde7e9;
        color: #a4262c;
        border: 1px solid #f3b7bd;
        padding: 10px 12px;
        margin-bottom: 12px;
        font-size: 13px;
        flex-direction: row;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
    }

    #errorBanner button {
        background: #a4262c;
        color: white;
        border: 0;
        padding: 6px 12px;
        cursor: pointer;
        border-radius: 2px;
        font-size: 12px;
    }

    .grid-container {
        display: grid;
        grid-template-columns: minmax(0, 58%) minmax(0, 42%);
        gap: 16px;
        align-items: start;
    }

    .grid-column-left,
    .grid-column-right {
        min-width: 0;
    }

    .grid-column-right .section {
        width: 100%;
    }

    .section {
        background: #ffffff;
        border: 1px solid #e1dfdd;
        padding: 14px 16px 12px 16px;
        box-sizing: border-box;
    }

    .grid-column-left .section + .section,
    .grid-column-right .section + .section {
        margin-top: 16px;
    }

    .section-title {
        font-size: 13px;
        font-weight: 600;
        margin-bottom: 12px;
        color: #201f1e;
    }

    .row {
        display: flex;
        align-items: center;
        margin-bottom: 10px;
    }

    .grid-column-left .label {
        width: 230px;
        min-width: 230px;
    }

    .grid-column-right .label {
        width: 200px;
        min-width: 200px;
    }

    .label {
        font-size: 12px;
        color: #605e5c;
        padding-right: 10px;
        box-sizing: border-box;
        line-height: 16px;
    }

    .d365-input {
        flex: 1;
        height: 30px;
        padding: 4px 8px;
        font-size: 12px;
        color: #201f1e;
        background-color: #edebe9;
        border: 1px solid #c8c6c4;
        border-radius: 0;
        box-sizing: border-box;
        outline: none;
    }

    @media (max-width: 1100px) {

        .grid-container {
            grid-template-columns: 1fr;
        }
    }

    @media (max-width: 700px) {

        .row {
            flex-direction: column;
            align-items: stretch;
        }

        .label {
            width: 100%;
            min-width: auto;
            margin-bottom: 4px;
            padding-right: 0;
        }

        .page-header {
            flex-direction: column;
            align-items: flex-start;
        }
    }

    @media print {

        @page {
            margin: 0.45in;
            size: letter;
        }

        html, body {
            background: #ffffff !important;
            padding: 0 !important;
            margin: 0 !important;
            color: #000000 !important;
            -webkit-print-color-adjust: exact;
            print-color-adjust: exact;
        }

        .no-print,
        #loader,
        #errorBanner {
            display: none !important;
        }

        .print-only {
            display: block !important;
        }

        .grid-container {
            display: grid !important;
            grid-template-columns: 1fr 1fr !important;
            gap: 14px !important;
        }

        .grid-column-left .section + .section,
        .grid-column-right .section + .section {
            margin-top: 12px !important;
        }

        .section {
            background: #ffffff !important;
            border: 1px solid #bdbdbd !important;
            padding: 10px 12px 8px 12px !important;
            page-break-inside: avoid;
            break-inside: avoid;
        }

        .section.hidden {
            display: none !important;
        }

        .section-title {
            font-size: 12px !important;
            font-weight: 700 !important;
            color: #000000 !important;
            border-bottom: 1px solid #0078d4;
            padding-bottom: 6px;
            margin-bottom: 8px !important;
            text-transform: uppercase;
            letter-spacing: 0.3px;
        }

        .row {
            display: flex !important;
            flex-direction: row !important;
            align-items: baseline !important;
            margin-bottom: 0 !important;
            padding: 5px 0;
            border-bottom: 1px solid #ececec;
        }

        .row:last-child {
            border-bottom: none;
        }

        .grid-column-left .label,
        .grid-column-right .label {
            width: 42% !important;
            min-width: 42% !important;
            font-size: 10px !important;
            color: #444444 !important;
            font-weight: 600 !important;
            padding-right: 8px !important;
        }

        .d365-input {
            flex: 1 !important;
            height: auto !important;
            min-height: 0 !important;
            padding: 0 !important;
            font-size: 10px !important;
            color: #000000 !important;
            background: transparent !important;
            border: none !important;
            font-weight: 500 !important;
        }
    }

</style>
</head>

