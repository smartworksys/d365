name: Infra_Deploy_$(BuildDefinitionName)_$(date:yyyyMMdd)$(rev:.r)

trigger: none

parameters:
- name: environment
  displayName: 'Deployment Environment'
  type: string
  default: 'dev'
  values:
  - dev
  - test
  - uat
  - uat2
  - prod

- name: veracode_scan
  displayName: 'VeraCode Scan'
  type: boolean
  default: false
  values:
    - true
    - false

- name: deploy_functionapp_workflows
  displayName: 'Deploy Function App Workflows'
  type: boolean
  default: false
  values:
    - true
    - false

variables:
- name: solutionPath
  value: 'KOFC-FA-AgentPortal-UserProfile/KOFC-FA-AgentPortal-UserProfile.sln'
- name: functionProject
  value: 'KOFC-FA-AgentPortal-UserProfile/KOFC-FA-AgentPortal-UserProfile.csproj'
- ${{ if eq(parameters.environment, 'dev') }}:
    - template: kofc-functionapp-variables/pipeline-vars-dev.yml
- ${{ if eq(parameters.environment, 'test') }}:
    - template: kofc-functionapp-variables/pipeline-vars-test.yml
- ${{ if eq(parameters.environment, 'uat') }}:
    - template: kofc-functionapp-variables/pipeline-vars-uat.yml
- ${{ if eq(parameters.environment, 'uat2') }}:
    - template: kofc-functionapp-variables/pipeline-vars-uat2.yml    
- ${{ if eq(parameters.environment, 'prod') }}:
    - template: kofc-functionapp-variables/pipeline-vars-prod.yml

stages:
  - stage: build_artifacts
    jobs:
      - job: function_app_build
        displayName: 'Build and publish function app'
        pool:
          name: Azure Pipelines
          vmImage: $(vmImageName)
        steps:

        - task: DotNetCoreCLI@2
          displayName: Restore
          inputs:
            command: restore
            projects: '$(solutionPath)'

        - task: DotNetCoreCLI@2
          displayName: Build
          inputs:
            command: build
            projects: '$(solutionPath)'
            arguments: --configuration Release --no-restore

        - task: DotNetCoreCLI@2
          displayName: Test
          inputs:
            command: test
            projects: '$(solutionPath)'
            arguments: --configuration Release --no-build --logger trx

        - task: DotNetCoreCLI@2
          displayName: Publish function app
          inputs:
            command: publish
            publishWebProjects: false
            projects: '$(functionProject)'
            arguments: --configuration Release --no-build --output $(System.DefaultWorkingDirectory)/publish_output
            zipAfterPublish: false

        - task: ArchiveFiles@2
          displayName: 'Archive files'
          inputs:
            rootFolderOrFile: '$(System.DefaultWorkingDirectory)/publish_output'
            includeRootFolder: false
            archiveType: zip
            archiveFile: $(Build.ArtifactStagingDirectory)/$(Build.BuildId).zip
            replaceExistingArchive: true
            
        - task: Veracode.veracode-vsts-build-extension.veracode-scanner-task.Veracode@3
          condition: eq('${{ parameters.veracode_scan }}', true)
          displayName: 'Veracode Scan'
          inputs:
            AnalysisService: 'Veracode_Platform'
            veracodeAppProfile: OneMember365
            filepath: '$(Build.ArtifactStagingDirectory)/$(Build.BuildId).zip'
            optargs: '-criticality high -include **/*.dll -exclude **/*.exe -createsandbox true -sandboxname OneMember-FunctionApps-Scan -deleteIncompleteScan 1'
            sandboxName: 'OneMember-FunctionApps-Scan'
            createSandBox: true
            importResults: true
            failBuildOnPolicyFail: true
            maximumWaitTime: 30

        - publish: $(Build.ArtifactStagingDirectory)/$(Build.BuildId).zip
          artifact: drop
 
  - stage: Deploy
    dependsOn: build_artifacts
    condition: succeeded()
    jobs:
    - deployment: Deploy
      displayName: Deploy
      environment: $(env)
      pool:
          name: Azure Pipelines
          vmImage: $(vmImageName)

      strategy:
        runOnce:
          deploy:

            steps:
            - task: AzureFunctionApp@1
              displayName: 'Azure functions app deploy'
              inputs:
                azureSubscription: '$(serviceConnection)'
                appType: functionApp
                appName: $(functionAppName)
                package: '$(Pipeline.Workspace)/drop/$(Build.BuildId).zip'
