<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Auth Callback / Results</title>
    <style>
        body { font-family: Segoe UI, Arial, sans-serif; margin: 24px; color: #333; max-width: 900px; }
        h1 { font-size: 1.15rem; }
        .msg { font-size: 0.95rem; }
        .err { color: #a4262c; }
        pre { background: #f3f2f1; border: 1px solid #ccc; padding: 12px; white-space: pre-wrap;
              word-break: break-all; font-size: 0.85rem; }
        a.button { display: inline-block; margin-top: 8px; }
    </style>
</head>
<body>
    <h1>Boomi Integration Validator — Result</h1>
    <p id="msg" class="msg">Completing sign-in...</p>
    <pre id="log"></pre>
    <script>
        (function () {
            "use strict";

            var CFG_KEY = "biv_cfg";
            var RESULT_KEY = "biv_result";
            var msgEl = document.getElementById("msg");
            var logEl = document.getElementById("log");

            function setMsg(text, isErr) {
                msgEl.textContent = text;
                msgEl.className = isErr ? "msg err" : "msg";
            }

            function log(text, isErr) {
                logEl.textContent += "[" + new Date().toLocaleTimeString() + "] " + text + "\n";
                if (isErr) { logEl.className = "err"; }
            }

            function readCfg() {
                try {
                    var raw = localStorage.getItem(CFG_KEY);
                    return raw ? JSON.parse(raw) : null;
                } catch (e) {
                    return null;
                }
            }

            function decodeJwtPayload(token) {
                try {
                    var parts = token.split(".");
                    if (parts.length < 2) { return null; }
                    var json = atob(parts[1].replace(/-/g, "+").replace(/_/g, "/"));
                    return JSON.parse(json);
                } catch (e) {
                    return null;
                }
            }

            async function callBoomi(cfg, token) {
                var query = new URLSearchParams({ userId: cfg.userId });
                if (cfg.oppId) { query.append("oppID", cfg.oppId); }
                var url = cfg.boomiUrl + (cfg.boomiUrl.indexOf("?") >= 0 ? "&" : "?") + query.toString();
                log("Calling Boomi: " + url);
                log("Sending headers: Authorization (Bearer), x-api-key");

                var response = await fetch(url, {
                    method: "GET",
                    headers: {
                        "Authorization": "Bearer " + token,
                        "x-api-key": cfg.boomiApiKey,
                        "Accept": "text/plain"
                    }
                });
                var body = await response.text();
                if (!response.ok) {
                    throw new Error("Boomi returned " + response.status + ": " + body);
                }
                return { status: response.status, body: body };
            }

            function loadScript(src) {
                return new Promise(function (resolve, reject) {
                    var s = document.createElement("script");
                    s.src = src;
                    s.onload = function () { resolve(typeof msal !== "undefined"); };
                    s.onerror = function () { reject(new Error("404: " + src)); };
                    document.head.appendChild(s);
                });
            }

            async function ensureMsal() {
                if (typeof msal !== "undefined") { return; }
                var base = window.location.origin + "/WebResources/";
                var names = [
                    "kofc_msal-browser.min.js", "kofc_msalbrowsermin",
                    "kofc_msal_browser_min", "kofc_msalbrowser.min.js", "kofc_msal-browser"
                ];
                for (var i = 0; i < names.length; i++) {
                    try {
                        await loadScript(base + names[i]);
                        if (typeof msal !== "undefined") { return; }
                    } catch (e) { /* try next */ }
                }
                throw new Error("MSAL library not found as a web resource.");
            }

            async function showResults(cfg, token) {
                var claims = decodeJwtPayload(token);
                setMsg("Sign-in complete.");
                if (claims) {
                    log("aud: " + (claims.aud || ""));
                    log("scp: " + (claims.scp || claims.roles || ""));
                    log("oid: " + (claims.oid || ""));
                    log("appid/azp: " + (claims.appid || claims.azp || ""));
                }
                log("Access token:\n" + token);

                if (cfg.action === "call") {
                    try {
                        var res = await callBoomi(cfg, token);
                        log("Boomi integration validation passed. HTTP " + res.status);
                        log("Response (first 200 chars): " + res.body.substring(0, 200));
                    } catch (e) {
                        setMsg("Boomi call failed.", true);
                        log("Boomi call failed: " + (e && e.message ? e.message : e), true);
                    }
                }
            }

            async function run() {
                // Inside the ssoSilent hidden iframe: do NOTHING. The validator (parent) reads
                // the hash itself; processing/navigating here would break silent SSO.
                if (window.self !== window.top) {
                    return;
                }

                if (window.location.hash.indexOf("code=") < 0 &&
                    window.location.hash.indexOf("error=") < 0 &&
                    window.location.search.indexOf("code=") < 0) {
                    setMsg("Auth callback page. Open the validator to start.");
                    return;
                }

                var cfg = readCfg();
                if (!cfg || !cfg.clientId || !cfg.tenantId) {
                    setMsg("Missing sign-in context. Start again from the validator.", true);
                    return;
                }

                try {
                    await ensureMsal();
                    var pca = new msal.PublicClientApplication({
                        auth: {
                            clientId: cfg.clientId,
                            authority: "https://login.microsoftonline.com/" + cfg.tenantId,
                            redirectUri: window.location.href.split("#")[0].split("?")[0]
                        },
                        cache: {
                            cacheLocation: "localStorage",
                            storeAuthStateInCookie: true
                        }
                    });

                    await pca.initialize();
                    var result = await pca.handleRedirectPromise();

                    if (result && result.accessToken) {
                        localStorage.setItem(RESULT_KEY, JSON.stringify({
                            accessToken: result.accessToken,
                            action: cfg.action || "token"
                        }));
                        await showResults(cfg, result.accessToken);
                        return;
                    }

                    setMsg("No token in the response. Start again from the validator.", true);
                } catch (e) {
                    setMsg("Sign-in failed.", true);
                    log((e && e.message ? e.message : String(e)), true);
                }
            }

            run();
        })();
    </script>
</body>
</html>

Object.keys(localStorage).filter(k => k.startsWith('biv_') || k.startsWith('msal')).forEach(k => localStorage.removeItem(k));
