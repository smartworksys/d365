function enableDisableNewButton(executionContext) {
    var formContext = executionContext.getFormContext();

    var statusFieldName = "kofc_status";
    var subgridControlName = "Subgrid_councilAllocations";
    var allowedStatuses = [258510002];

    var statusField = formContext.getAttribute(statusFieldName);
    if (statusField == null) {
        console.log("Status field not found: " + statusFieldName);
        return;
    }

    var statusValue = statusField.getValue();
    console.log("Status value on load:", statusValue);

    var isEnabled = allowedStatuses.indexOf(statusValue) !== -1;
    console.log("Button should be enabled:", isEnabled);

    // Start watching DOM for subgrid and button
    watchForButton(subgridControlName, isEnabled);

    // Handle when status field changes
    statusField.addOnChange(function () {
        var newValue = statusField.getValue();
        console.log("Status changed to:", newValue);
        var enabled = allowedStatuses.indexOf(newValue) !== -1;
        watchForButton(subgridControlName, enabled);
    });
}

function watchForButton(subgridControlName, isEnabled) {
    console.log("Watching DOM for button...");

    // First try immediately
    var result = tryToggleButton(subgridControlName, isEnabled);
    if (result) return;

    // If not found, use MutationObserver to watch for DOM changes
    var observer = new MutationObserver(function (mutations, obs) {
        var result = tryToggleButton(subgridControlName, isEnabled);
        if (result) {
            console.log("Button found via MutationObserver, stopping watch.");
            obs.disconnect(); // Stop watching once button is found
        }
    });

    // Watch entire document for changes
    observer.observe(document.body, {
        childList: true,
        subtree: true
    });

    // Safety timeout — stop watching after 30 seconds
    setTimeout(function () {
        observer.disconnect();
        console.log("MutationObserver stopped after 30 seconds.");
    }, 30000);
}

function tryToggleButton(subgridControlName, isEnabled) {
    // Find subgrid
    var subgridEl = document.querySelector("[data-control-name='" + subgridControlName + "']");

    if (!subgridEl) {
        console.log("Subgrid not in DOM yet...");
        return false;
    }

    console.log("Subgrid found in DOM");

    // Find New button
    var newButton = subgridEl.querySelector("button[data-id*='AddNewStandard']");

    if (!newButton) {
        console.log("New button not in DOM yet...");
        // Log all buttons for debugging
        var allBtns = subgridEl.querySelectorAll("button");
        if (allBtns.length > 0) {
            console.log("Buttons found so far:", allBtns.length);
            allBtns.forEach(function(btn, i) {
                console.log("Button " + i + ":", {
                    dataId: btn.getAttribute("data-id"),
                    label: btn.getAttribute("aria-label")
                });
            });
        }
        return false;
    }

    console.log("New button found, toggling...");

    // Toggle button
    if (isEnabled) {
        console.log("Enabling New button");
        newButton.disabled = false;
        newButton.style.opacity = "1";
        newButton.style.cursor = "pointer";
        newButton.style.pointerEvents = "auto";
    } else {
        console.log("Disabling New button");
        newButton.disabled = true;
        newButton.style.opacity = "0.5";
        newButton.style.cursor = "not-allowed";
        newButton.style.pointerEvents = "none";
    }

    return true; // Success
}
