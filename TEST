
/*
 * KOFC EApp SSO - Boomi call from a Dynamics 365 command bar button.
 *
 * Wire-up (Command designer / ribbon):
 *   Function name:  KOFC.Eapp.callBoomi
 *   Library:        kofc_eappBoomiCall.js
 *   Parameter:      PrimaryControl   (pass the form context)
 *
 * Prerequisites (already uploaded as web resources):
 *   - kofc_msal-browser.min.js   (MSAL library)
 *   - kofc_eappAuthCallback.html (MSAL redirect URI page; must be registered in Entra as an SPA redirect URI)
 *
 * SECURITY NOTE: x-api-key lives in client-side script and is visible to any form user.
 * Prefer having Boomi authorize on the user's bearer token instead of a shared key. If a key
 * is required, treat it as low-sensitivity and rotate it. Ideally move CONFIG values into a
 * Dataverse environment variable and read them via Xrm.WebApi rather than hard-coding here.
 */
var KOFC = KOFC || {};

KOFC.Eapp = (function () {
    "use strict";

    var CONFIG = {
        tenantId: "<TENANT_ID>",
        clientId: "<SPA_CLIENT_ID>",
        apiAppId: "<FUNCTION_API_APP_ID>",
        scope: "access_as_user",
        boomiUrl: "https://<boomi-host>/ws/rest/YourProcess",
        httpMethod: "POST",
        apiKey: "<X_API_KEY>",
        // Served + Entra-registered redirect page. Leave null to use the default below.
        redirectUri: null,
        msalWebResourcePath: "/WebResources/kofc_msal-browser.min.js"
    };

    var msalApp = null;
    var msalLoad = null;

    function origin() {
        return window.location.origin;
    }

    function redirectUri() {
        return CONFIG.redirectUri || (origin() + "/WebResources/kofc_eappAuthCallback.html");
    }

    function scopes() {
        return ["api://" + CONFIG.apiAppId + "/" + CONFIG.scope];
    }

    function stripBraces(value) {
        return (value || "").replace(/[{}]/g, "").trim();
    }

    function loadMsal() {
        if (typeof msal !== "undefined") {
            return Promise.resolve();
        }
        if (msalLoad) {
            return msalLoad;
        }
        msalLoad = new Promise(function (resolve, reject) {
            var s = document.createElement("script");
            s.src = origin() + CONFIG.msalWebResourcePath;
            s.onload = function () {
                if (typeof msal !== "undefined") {
                    resolve();
                } else {
                    reject(new Error("MSAL loaded but global 'msal' is undefined."));
                }
            };
            s.onerror = function () {
                reject(new Error("Failed to load MSAL web resource: " + s.src));
            };
            document.head.appendChild(s);
        });
        return msalLoad;
    }

    async function initMsal() {
        if (msalApp) {
            return msalApp;
        }
        await loadMsal();
        msalApp = new msal.PublicClientApplication({
            auth: {
                clientId: CONFIG.clientId,
                authority: "https://login.microsoftonline.com/" + CONFIG.tenantId,
                redirectUri: redirectUri()
            },
            cache: {
                cacheLocation: "localStorage",
                storeAuthStateInCookie: true
            }
        });
        await msalApp.initialize();
        // Complete any in-flight redirect (harmless if none).
        await msalApp.handleRedirectPromise();
        return msalApp;
    }

    async function getToken(loginHint) {
        await initMsal();

        // 1) Silent from a cached account.
        var accounts = msalApp.getAllAccounts();
        if (accounts && accounts.length > 0) {
            try {
                var silent = await msalApp.acquireTokenSilent({
                    scopes: scopes(),
                    account: accounts[0]
                });
                return silent.accessToken;
            } catch (e) {
                // fall through
            }
        }

        // 2) ssoSilent using the signed-in D365 user (hidden iframe, no UI).
        try {
            var sso = await msalApp.ssoSilent({
                scopes: scopes(),
                loginHint: loginHint || undefined
            });
            return sso.accessToken;
        } catch (e) {
            // fall through
        }

        // 3) Interactive popup (button click is a user gesture, keeps the form intact).
        var popupReq = { scopes: scopes() };
        if (loginHint) {
            popupReq.loginHint = loginHint;
        }
        var popup = await msalApp.acquireTokenPopup(popupReq);
        return popup.accessToken;
    }

    function buildUrl(userId, oppId, boomiUrl) {
        var base = boomiUrl || CONFIG.boomiUrl;
        var qs = "userId=" + encodeURIComponent(userId);
        if (oppId) {
            qs += "&oppID=" + encodeURIComponent(oppId);
        }
        return base + (base.indexOf("?") >= 0 ? "&" : "?") + qs;
    }

    async function callBoomiApi(token, userId, oppId, boomiUrl) {
        var method = (CONFIG.httpMethod || "POST").toUpperCase();
        var options = {
            method: method,
            headers: {
                "Authorization": "Bearer " + token,
                "x-api-key": CONFIG.apiKey,
                "Accept": "text/plain"
            }
        };
        if (method !== "GET" && method !== "HEAD") {
            options.headers["Content-Type"] = "application/json";
            options.body = JSON.stringify({ userId: userId, oppID: oppId || undefined });
        }

        var response = await fetch(buildUrl(userId, oppId, boomiUrl), options);
        var body = await response.text();
        if (!response.ok) {
            throw new Error("Boomi returned " + response.status + ": " + body);
        }
        return { status: response.status, body: body };
    }

    function deriveLoginHint() {
        try {
            var loginHint = Xrm.Utility.getGlobalContext().userSettings.userName;
            return (loginHint && loginHint.indexOf("@") >= 0) ? loginHint : null;
        } catch (e) {
            return null;
        }
    }

    // Public: acquire the delegated user access token (silent -> ssoSilent -> popup).
    async function getAccessToken() {
        return getToken(deriveLoginHint());
    }

    // Public: acquire a token and call Boomi at the given URL, returning the raw response body.
    // Use this from existing code that handles the response itself (e.g. opens the EApp URL).
    async function callBoomiRaw(boomiUrl, userId, oppId) {
        var token = await getToken(deriveLoginHint());
        var result = await callBoomiApi(
            token,
            stripBraces(userId),
            stripBraces(oppId),
            boomiUrl || CONFIG.boomiUrl
        );
        return result.body;
    }

    // Entry point for the command bar button. Pass PrimaryControl as the parameter.
    async function callBoomi(primaryControl) {
        try {
            var gctx = Xrm.Utility.getGlobalContext();
            var userId = stripBraces(gctx.userSettings.userId);
            var loginHint = deriveLoginHint();

            var oppId = "";
            if (primaryControl && primaryControl.data && primaryControl.data.entity
                && primaryControl.data.entity.getEntityName
                && primaryControl.data.entity.getEntityName() === "opportunity") {
                oppId = stripBraces(primaryControl.data.entity.getId());
            }

            if (!userId) {
                throw new Error("Could not determine the current user's systemuserid.");
            }

            var token = await getToken(loginHint);
            var result = await callBoomiApi(token, userId, oppId);

            await Xrm.Navigation.openAlertDialog({
                title: "EApp SSO",
                text: "Boomi call succeeded (HTTP " + result.status + ")."
            });
            return result.body;
        } catch (e) {
            var message = (e && e.message) ? e.message : String(e);
            if (Xrm.Navigation.openErrorDialog) {
                Xrm.Navigation.openErrorDialog({ message: "Boomi call failed: " + message });
            } else {
                Xrm.Navigation.openAlertDialog({ title: "EApp SSO - Error", text: message });
            }
        }
    }

    return {
        callBoomi: callBoomi,
        getAccessToken: getAccessToken,
        callBoomiRaw: callBoomiRaw
    };
})();


function callEappFunctionAPP(userID, OppID, eappURL, eappIntFunAppURL) {
    // eappIntFunAppURL is now the BOOMI endpoint (base URL, no ?code=).
    // KOFC.Eapp.callBoomiRaw acquires the user's MSAL token, adds x-api-key,
    // appends userId/oppID, calls Boomi, and returns the Base64 response body.
    Xrm.Utility.showProgressIndicator("Processing Request... Please Wait.");

    KOFC.Eapp.callBoomiRaw(eappIntFunAppURL, userID, OppID)
        .then(function (base64encodedStr) {
            var ssoURL = eappURL + "?soreq=" + base64encodedStr;
            Xrm.Utility.closeProgressIndicator();
            window.open(ssoURL, "_blank");
        })
        .catch(function (err) {
            Xrm.Utility.closeProgressIndicator();
            Xrm.Navigation.openAlertDialog({
                text: (err && err.message) ? err.message : String(err)
            });
        });
}
