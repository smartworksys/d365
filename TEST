using System.Diagnostics;
using System.Text;
using System.Windows;
using CommunityToolkit.Mvvm.ComponentModel;
using CommunityToolkit.Mvvm.Input;
using D365EnvAnalyzer.Models;

namespace D365EnvAnalyzer.ViewModels;

public partial class DetailViewModel : ObservableObject
{
    [ObservableProperty] private EnvVarAnalysisRow? _selectedRow;
    [ObservableProperty] private bool _isOpen;
    [ObservableProperty] private string _copyFeedback = string.Empty;

    private string _environmentUrl = string.Empty;

    public void SetEnvironmentUrl(string url) => _environmentUrl = url;

    public void ShowDetail(EnvVarAnalysisRow row)
    {
        SelectedRow = row;
        IsOpen = true;
        CopyFeedback = string.Empty;
    }

    [RelayCommand]
    private void Close()
    {
        IsOpen = false;
        SelectedRow = null;
    }

    [RelayCommand]
    private void CopyValue(string value)
    {
        if (string.IsNullOrEmpty(value)) return;
        Clipboard.SetText(value);
        ShowFeedback("Value copied");
    }

    [RelayCommand]
    private void CopySnippet(ComponentReference component)
    {
        if (string.IsNullOrEmpty(component.MatchSnippet)) return;
        Clipboard.SetText(component.MatchSnippet);
        ShowFeedback("Code block copied");
    }

    [RelayCommand]
    private void CopyAllDetails()
    {
        if (SelectedRow is null) return;

        var sb = new StringBuilder();
        sb.AppendLine($"═══ {SelectedRow.DisplayName} ═══");
        sb.AppendLine($"Schema Name:   {SelectedRow.SchemaName}");
        sb.AppendLine($"Type:          {SelectedRow.Type}");
        sb.AppendLine($"Default Value: {SelectedRow.DefaultValue}");
        sb.AppendLine($"Current Value: {SelectedRow.CurrentValue}");
        sb.AppendLine($"Delta:         {SelectedRow.Delta}");
        sb.AppendLine($"References:    {SelectedRow.References.Count}");
        sb.AppendLine($"Needs Fix:     {SelectedRow.NeedsAttentionCount}");
        sb.AppendLine();

        foreach (var r in SelectedRow.References)
        {
            sb.AppendLine($"──── {r.ComponentName} ({r.ComponentType}) ────");
            sb.AppendLine($"  ID:     {r.ComponentId}");
            sb.AppendLine($"  Usage:  {r.UsageSummary}");
            sb.AppendLine($"  Status: {(r.NeedsAttention ? "⚠ NEEDS FIX" : "OK")}");
            if (!string.IsNullOrEmpty(r.MatchSnippet))
            {
                sb.AppendLine($"  Code:");
                foreach (var line in r.MatchSnippet.Split('\n'))
                    sb.AppendLine($"    {line}");
            }
            sb.AppendLine();
        }

        Clipboard.SetText(sb.ToString());
        ShowFeedback("All details copied to clipboard");
    }

    [RelayCommand]
    private void OpenInD365(ComponentReference component)
    {
        if (string.IsNullOrEmpty(_environmentUrl)) return;
        var url = BuildComponentUrl(component);
        try
        {
            Process.Start(new ProcessStartInfo(url) { UseShellExecute = true });
        }
        catch { }
    }

    private string BuildComponentUrl(ComponentReference c)
    {
        var id = c.ComponentId.ToString("D");
        return c.EntityLogicalName switch
        {
            "workflow" => $"{_environmentUrl}/main.aspx?etn=workflow&pagetype=entityrecord&id=%7b{id}%7d",
            "canvasapp" => $"{_environmentUrl}/main.aspx?etn=canvasapp&pagetype=entityrecord&id=%7b{id}%7d",
            "webresource" => $"{_environmentUrl}/main.aspx?etn=webresource&pagetype=entityrecord&id=%7b{id}%7d",
            "sdkmessageprocessingstep" => $"{_environmentUrl}/main.aspx?etn=sdkmessageprocessingstep&pagetype=entityrecord&id=%7b{id}%7d",
            "sitemap" => $"{_environmentUrl}/main.aspx?etn=sitemap&pagetype=entityrecord&id=%7b{id}%7d",
            "connectionreference" => $"{_environmentUrl}/main.aspx?etn=connectionreference&pagetype=entityrecord&id=%7b{id}%7d",
            _ => $"{_environmentUrl}/main.aspx?pagetype=entityrecord&id=%7b{id}%7d"
        };
    }

    private async void ShowFeedback(string msg)
    {
        CopyFeedback = msg;
        await Task.Delay(2000);
        if (CopyFeedback == msg) CopyFeedback = string.Empty;
    }
}






<Window x:Class="D365EnvAnalyzer.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:models="clr-namespace:D365EnvAnalyzer.Models"
        Title="D365 Env Variables Analyzer"
        Width="1400" Height="850"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="{DynamicResource MaterialDesign.Brush.Background}"
        FontFamily="{md:MaterialDesignFont}"
        TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Foreground}">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Delta to color dot -->
        <Style x:Key="StatusDot" TargetType="Ellipse">
            <Setter Property="Width" Value="12"/>
            <Setter Property="Height" Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Toolbar -->
            <RowDefinition Height="Auto"/>  <!-- Filter bar -->
            <RowDefinition Height="Auto"/>  <!-- Error banner -->
            <RowDefinition Height="*"/>     <!-- Content -->
        </Grid.RowDefinitions>

        <!-- ═══════ TOOLBAR ═══════ -->
        <md:ColorZone Grid.Row="0" Mode="PrimaryDark" Padding="12,8"
                       md:ElevationAssist.Elevation="Dp4">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <md:PackIcon Kind="CloudSearch" Width="28" Height="28"
                                 Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <TextBlock Text="D365 Env Variables Analyzer"
                               Style="{StaticResource MaterialDesignHeadline6TextBlock}"
                               VerticalAlignment="Center" Foreground="White"/>
                    <TextBlock Text="{Binding ConnectedUrl}" Margin="20,0,0,0"
                               VerticalAlignment="Center" Foreground="#B0BEC5"
                               Style="{StaticResource MaterialDesignBody2TextBlock}"/>
                    <Border Background="#26FFFFFF" CornerRadius="10" Padding="10,3"
                            Margin="12,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding ScopeLabel}" Foreground="#B0BEC5"
                                   FontSize="12"/>
                    </Border>
                </StackPanel>

                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button Content="Refresh" Command="{Binding AnalyzeCommand}"
                            Style="{StaticResource MaterialDesignOutlinedLightButton}"
                            Margin="4,0"/>
                    <Button Content="Export Excel" Command="{Binding ExportExcelCommand}"
                            Style="{StaticResource MaterialDesignOutlinedLightButton}"
                            Margin="4,0"/>
                    <Button Content="Export CSV" Command="{Binding ExportCsvCommand}"
                            Style="{StaticResource MaterialDesignOutlinedLightButton}"
                            Margin="4,0"/>
                    <ToggleButton Style="{StaticResource MaterialDesignSwitchLightToggleButton}"
                                  IsChecked="{Binding IsDarkMode}"
                                  Command="{Binding ToggleThemeCommand}"
                                  ToolTip="Toggle Dark/Light Mode"
                                  Margin="12,0"/>
                    <Button Content="Disconnect" Command="{Binding DisconnectCommand}"
                            Style="{StaticResource MaterialDesignOutlinedLightButton}"
                            Margin="4,0" Foreground="#EF9A9A"/>
                </StackPanel>
            </DockPanel>
        </md:ColorZone>

        <!-- ═══════ FILTER BAR ═══════ -->
        <md:Card Grid.Row="1" Margin="12,8,12,4" Padding="12,8"
                  md:ElevationAssist.Elevation="Dp1">
            <StackPanel Orientation="Horizontal">
                <md:PackIcon Kind="Magnify" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox Width="280"
                         md:HintAssist.Hint="Search by name or schema…"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         VerticalAlignment="Center"/>

                <TextBlock Text="Delta:" Margin="24,0,8,0" VerticalAlignment="Center"/>
                <ComboBox Width="140"
                          ItemsSource="{Binding DeltaFilterOptions}"
                          SelectedItem="{Binding SelectedDeltaFilter}"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                          VerticalAlignment="Center"/>

                <TextBlock Text="Component:" Margin="24,0,8,0" VerticalAlignment="Center"/>
                <ComboBox Width="180"
                          ItemsSource="{Binding ComponentFilterOptions}"
                          SelectedItem="{Binding SelectedComponentFilter}"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                          VerticalAlignment="Center"/>

                <TextBlock Text="Usage:" Margin="24,0,8,0" VerticalAlignment="Center"/>
                <ComboBox Width="230"
                          ItemsSource="{Binding UsageFilterOptions}"
                          SelectedItem="{Binding SelectedUsageFilter}"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                          VerticalAlignment="Center"/>
            </StackPanel>
        </md:Card>

        <!-- ═══════ ERROR BANNER ═══════ -->
        <Border Grid.Row="2" Background="#D32F2F" Padding="12,8"
                Margin="12,4" CornerRadius="4"
                Visibility="{Binding HasErrorBanner, Converter={StaticResource BoolToVis}}">
            <DockPanel>
                <Button DockPanel.Dock="Right" Content="✕"
                        Command="{Binding DismissErrorCommand}"
                        Foreground="White" Background="Transparent"
                        BorderThickness="0" Cursor="Hand"/>
                <TextBlock Text="{Binding ErrorBanner}" Foreground="White"
                           TextWrapping="Wrap" VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <!-- ═══════ MAIN CONTENT: GRID + DETAIL SPLIT ═══════ -->
        <Grid Grid.Row="3" Margin="12,4,12,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Data Grid -->
            <DataGrid Grid.Column="0"
                      ItemsSource="{Binding FilteredRows}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserSortColumns="True"
                      EnableRowVirtualization="True"
                      VirtualizingPanel.IsVirtualizing="True"
                      VirtualizingPanel.VirtualizationMode="Recycling"
                      SelectionMode="Single"
                      SelectedItem="{Binding DetailVm.SelectedRow, Mode=OneWayToSource}"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column"
                      Background="Transparent"
                      RowBackground="Transparent"
                      AlternatingRowBackground="{DynamicResource MaterialDesign.Brush.Card.Background}">

                <DataGrid.InputBindings>
                    <MouseBinding MouseAction="LeftDoubleClick"
                                  Command="{Binding ShowDetailCommand}"
                                  CommandParameter="{Binding FilteredRows/}"/>
                </DataGrid.InputBindings>

                <DataGrid.Columns>
                    <!-- Status dot -->
                    <DataGridTemplateColumn Header="⬤" Width="40" CanUserSort="True"
                                            SortMemberPath="Delta">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Ellipse Width="12" Height="12"
                                         VerticalAlignment="Center"
                                         HorizontalAlignment="Center">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill" Value="#9E9E9E"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Delta}" Value="Same">
                                                    <Setter Property="Fill" Value="#4CAF50"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Delta}" Value="Changed">
                                                    <Setter Property="Fill" Value="#FFC107"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Delta}" Value="Missing">
                                                    <Setter Property="Fill" Value="#F44336"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Delta}" Value="NoDefault">
                                                    <Setter Property="Fill" Value="#9E9E9E"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Display Name -->
                    <DataGridTextColumn Header="Display Name" Binding="{Binding DisplayName}"
                                        Width="220">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Padding" Value="4,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- Schema Name -->
                    <DataGridTextColumn Header="Schema Name" Binding="{Binding SchemaName}"
                                        Width="260">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontFamily" Value="Cascadia Code,Consolas,Courier New"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Padding" Value="4,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- Type -->
                    <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="100"/>

                    <!-- Default Value -->
                    <DataGridTextColumn Header="Default Value" Binding="{Binding DefaultValue}"
                                        Width="180">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                <Setter Property="ToolTip" Value="{Binding DefaultValue}"/>
                                <Setter Property="Padding" Value="4,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- Current Value -->
                    <DataGridTemplateColumn Header="Current Value" Width="180"
                                            SortMemberPath="CurrentValue">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Padding="4,2">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Delta}" Value="Changed">
                                                    <Setter Property="Background" Value="#33FFC107"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding CurrentValue}"
                                               TextTrimming="CharacterEllipsis"
                                               ToolTip="{Binding CurrentValue}"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Delta -->
                    <DataGridTemplateColumn Header="Delta" Width="100" SortMemberPath="Delta">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock VerticalAlignment="Center" Padding="4,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Delta}" Value="Same">
                                                    <Setter Property="Text" Value="Same"/>
                                                    <Setter Property="Foreground" Value="#4CAF50"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Delta}" Value="Changed">
                                                    <Setter Property="Text" Value="Changed ✎"/>
                                                    <Setter Property="Foreground" Value="#FFC107"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Delta}" Value="Missing">
                                                    <Setter Property="Text" Value="Unset"/>
                                                    <Setter Property="Foreground" Value="#F44336"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Delta}" Value="NoDefault">
                                                    <Setter Property="Text" Value="—"/>
                                                    <Setter Property="Foreground" Value="#9E9E9E"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Referenced By -->
                    <DataGridTemplateColumn Header="Referenced By" Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Padding="4,0" TextTrimming="CharacterEllipsis"
                                           VerticalAlignment="Center"
                                           Text="{Binding ReferencesSummary}"
                                           ToolTip="{Binding ReferencesSummary}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

            <!-- ═══════ DETAIL SIDE PANEL ═══════ -->
            <Border Grid.Column="1" Width="480" Margin="8,0,0,0"
                    Background="{DynamicResource MaterialDesign.Brush.Card.Background}"
                    CornerRadius="10" Padding="0"
                    Visibility="{Binding DetailVm.IsOpen, Converter={StaticResource BoolToVis}}"
                    Effect="{StaticResource MaterialDesignShadowDepth3}">

                <Grid DataContext="{Binding DetailVm}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- ─── Header ─── -->
                    <Border Grid.Row="0" Padding="16,12" CornerRadius="10,10,0,0"
                            Background="{DynamicResource MaterialDesign.Brush.Primary}">
                        <DockPanel>
                            <Button DockPanel.Dock="Right" Content="✕"
                                    Command="{Binding CloseCommand}"
                                    Foreground="White" Margin="8,0,0,0"
                                    Style="{StaticResource MaterialDesignIconButton}"/>
                            <StackPanel>
                                <TextBlock Text="{Binding SelectedRow.DisplayName}"
                                           FontSize="16" FontWeight="Bold"
                                           Foreground="White" TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="{Binding SelectedRow.SchemaName}"
                                           FontSize="11" Foreground="#BBFFFFFF"
                                           FontFamily="Cascadia Code,Consolas"
                                           TextTrimming="CharacterEllipsis"
                                           Margin="0,2,0,0"/>
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <!-- ─── Scrollable Content ─── -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                                  Padding="16,12,16,8">
                        <StackPanel>

                            <!-- Type + Delta chips -->
                            <WrapPanel Margin="0,0,0,12">
                                <Border CornerRadius="12" Padding="10,4" Margin="0,0,6,0"
                                        Background="{DynamicResource MaterialDesign.Brush.Primary.Light}">
                                    <TextBlock Text="{Binding SelectedRow.Type}" FontSize="11"
                                               Foreground="{DynamicResource MaterialDesign.Brush.Primary.Foreground}"/>
                                </Border>
                                <Border CornerRadius="12" Padding="10,4" Margin="0,0,6,0">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#E0E0E0"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedRow.Delta}" Value="Changed">
                                                    <Setter Property="Background" Value="#FFF3E0"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding SelectedRow.Delta}" Value="Missing">
                                                    <Setter Property="Background" Value="#FFEBEE"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding SelectedRow.Delta}" FontSize="11"/>
                                </Border>
                                <Border CornerRadius="12" Padding="10,4">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#E8F5E9"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedRow.NeedsAttentionCount, 
                                                              Converter={StaticResource BoolToVis}}" Value="Visible">
                                                    <Setter Property="Background" Value="#FFF3E0"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock FontSize="11"
                                               Text="{Binding SelectedRow.ReferencesSummary}"/>
                                </Border>
                            </WrapPanel>

                            <!-- Default Value -->
                            <DockPanel Margin="0,0,0,2">
                                <TextBlock Text="Default Value" Foreground="Gray" FontSize="11"
                                           VerticalAlignment="Center"/>
                                <Button DockPanel.Dock="Right" ToolTip="Copy default value"
                                        Command="{Binding CopyValueCommand}"
                                        CommandParameter="{Binding SelectedRow.DefaultValue}"
                                        Height="22" Width="22" Padding="0"
                                        Style="{StaticResource MaterialDesignToolFlatButton}">
                                    <md:PackIcon Kind="ContentCopy" Width="14" Height="14"/>
                                </Button>
                            </DockPanel>
                            <TextBox Text="{Binding SelectedRow.DefaultValue, Mode=OneWay}"
                                     IsReadOnly="True" TextWrapping="Wrap"
                                     MaxHeight="100" VerticalScrollBarVisibility="Auto"
                                     Margin="0,0,0,10" Padding="8,6"
                                     FontFamily="Cascadia Code,Consolas" FontSize="12"
                                     Background="#08000000" BorderBrush="#20808080"
                                     BorderThickness="1"/>

                            <!-- Current Value -->
                            <DockPanel Margin="0,0,0,2">
                                <TextBlock Text="Current Value" Foreground="Gray" FontSize="11"
                                           VerticalAlignment="Center"/>
                                <Button DockPanel.Dock="Right" ToolTip="Copy current value"
                                        Command="{Binding CopyValueCommand}"
                                        CommandParameter="{Binding SelectedRow.CurrentValue}"
                                        Height="22" Width="22" Padding="0"
                                        Style="{StaticResource MaterialDesignToolFlatButton}">
                                    <md:PackIcon Kind="ContentCopy" Width="14" Height="14"/>
                                </Button>
                            </DockPanel>
                            <TextBox Text="{Binding SelectedRow.CurrentValue, Mode=OneWay}"
                                     IsReadOnly="True" TextWrapping="Wrap"
                                     MaxHeight="100" VerticalScrollBarVisibility="Auto"
                                     Margin="0,0,0,14" Padding="8,6"
                                     FontFamily="Cascadia Code,Consolas" FontSize="12"
                                     Background="#08000000" BorderBrush="#20808080"
                                     BorderThickness="1"/>

                            <!-- Separator -->
                            <Separator Margin="0,0,0,10"/>

                            <!-- References header -->
                            <DockPanel Margin="0,0,0,8">
                                <TextBlock VerticalAlignment="Center"
                                           FontSize="14" FontWeight="SemiBold">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="Referencing Components ({0})">
                                            <Binding Path="SelectedRow.References.Count"/>
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                            </DockPanel>

                            <!-- Component cards -->
                            <ItemsControl ItemsSource="{Binding SelectedRow.References}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type models:ComponentReference}">
                                        <md:Card Margin="0,0,0,8" Padding="12"
                                                  md:ElevationAssist.Elevation="Dp1">
                                            <md:Card.Style>
                                                <Style TargetType="md:Card">
                                                    <Setter Property="Background"
                                                            Value="{DynamicResource MaterialDesign.Brush.Card.Background}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding NeedsAttention}" Value="True">
                                                            <Setter Property="Background" Value="#FFF8E1"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsHardcoded}" Value="True">
                                                            <Setter Property="Background" Value="#FFF3E0"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </md:Card.Style>
                                            <StackPanel>
                                                <!-- Component header -->
                                                <DockPanel>
                                                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                                        <Button ToolTip="Copy code block"
                                                                Command="{Binding DataContext.CopySnippetCommand,
                                                                          RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                CommandParameter="{Binding}"
                                                                Height="26" Width="26" Padding="0"
                                                                Style="{StaticResource MaterialDesignToolFlatButton}">
                                                            <md:PackIcon Kind="ContentCopy" Width="14" Height="14"/>
                                                        </Button>
                                                        <Button Content="Open"
                                                                ToolTip="Open in Dynamics 365"
                                                                Command="{Binding DataContext.OpenInD365Command,
                                                                          RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                CommandParameter="{Binding}"
                                                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                                                Height="26" FontSize="10" Padding="8,0"
                                                                Margin="4,0,0,0"/>
                                                    </StackPanel>
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding ComponentName}"
                                                                   FontWeight="SemiBold" FontSize="13"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   ToolTip="{Binding ComponentName}"/>
                                                        <TextBlock FontSize="11" Foreground="Gray"
                                                                   Margin="0,1,0,0">
                                                            <Run Text="{Binding ComponentType, Mode=OneWay}"/>
                                                            <Run Text="·" Foreground="#CCC"/>
                                                            <Run Text="{Binding UsageCategory, Mode=OneWay}"/>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </DockPanel>

                                                <!-- Usage badge -->
                                                <TextBlock Text="{Binding UsageSummary}"
                                                           FontSize="11" Margin="0,6,0,0"
                                                           TextWrapping="Wrap">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="#4CAF50"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsHardcoded}" Value="True">
                                                                    <Setter Property="Foreground" Value="#E65100"/>
                                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding NeedsAttention}" Value="True">
                                                                    <Setter Property="Foreground" Value="#FF6F00"/>
                                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>

                                                <!-- Code block -->
                                                <TextBox Text="{Binding MatchSnippet, Mode=OneWay}"
                                                         FontSize="10.5"
                                                         FontFamily="Cascadia Code,Consolas"
                                                         IsReadOnly="True"
                                                         TextWrapping="NoWrap"
                                                         MaxHeight="200"
                                                         VerticalScrollBarVisibility="Auto"
                                                         HorizontalScrollBarVisibility="Auto"
                                                         Margin="0,6,0,0" Padding="8,6"
                                                         Background="#0C000000"
                                                         BorderThickness="1"
                                                         BorderBrush="#20808080"
                                                         md:TextFieldAssist.DecorationVisibility="Collapsed">
                                                    <TextBox.Style>
                                                        <Style TargetType="TextBox">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding MatchSnippet}" Value="">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBox.Style>
                                                </TextBox>
                                            </StackPanel>
                                        </md:Card>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- ─── Footer ─── -->
                    <Border Grid.Row="2" Padding="12,8" CornerRadius="0,0,10,10"
                            Background="{DynamicResource MaterialDesign.Brush.Background}">
                        <DockPanel>
                            <Button DockPanel.Dock="Right"
                                    Content="Copy All"
                                    ToolTip="Copy full variable details to clipboard"
                                    Command="{Binding CopyAllDetailsCommand}"
                                    Style="{StaticResource MaterialDesignFlatButton}"
                                    Height="30" FontSize="11" Padding="12,0">
                                <Button.ContentTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <md:PackIcon Kind="ContentCopy" Width="14" Height="14"
                                                         Margin="0,0,6,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="Copy All" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </Button.ContentTemplate>
                            </Button>
                            <TextBlock Text="{Binding CopyFeedback}"
                                       VerticalAlignment="Center"
                                       FontSize="11" Foreground="#4CAF50"
                                       FontWeight="SemiBold"/>
                        </DockPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- ═══════ PROGRESS OVERLAY ═══════ -->
        <Grid Grid.RowSpan="4"
              Visibility="{Binding IsAnalyzing, Converter={StaticResource BoolToVis}}">
            <Border Background="#88000000"/>
            <md:Card Padding="32" HorizontalAlignment="Center" VerticalAlignment="Center"
                      md:ElevationAssist.Elevation="Dp8" MinWidth="340">
                <StackPanel HorizontalAlignment="Center">
                    <ProgressBar IsIndeterminate="True" Width="260" Height="6" Margin="0,0,0,16"/>
                    <TextBlock Text="{Binding ProgressText}"
                               Style="{StaticResource MaterialDesignBody1TextBlock}"
                               HorizontalAlignment="Center" Margin="0,0,0,16"/>
                    <Button Content="Cancel" Command="{Binding CancelAnalysisCommand}"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            HorizontalAlignment="Center"/>
                </StackPanel>
            </md:Card>
        </Grid>

        <!-- Status bar -->
        <Border Grid.Row="3" VerticalAlignment="Bottom" Padding="12,6"
                Background="{DynamicResource MaterialDesign.Brush.Card.Background}">
            <TextBlock Text="{Binding ProgressText}"
                       Style="{StaticResource MaterialDesignCaptionTextBlock}"
                       Foreground="{DynamicResource MaterialDesign.Brush.Foreground.Light}"/>
        </Border>
    </Grid>
</Window>
