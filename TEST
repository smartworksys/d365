<Window x:Class="D365EnvAnalyzer.Views.SolutionPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Scan Configuration"
        Width="920" Height="640"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource MaterialDesign.Brush.Background}"
        FontFamily="{md:MaterialDesignFont}"
        TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Foreground}">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="Scan Configuration"
                   Style="{StaticResource MaterialDesignHeadline5TextBlock}"
                   Margin="0,0,0,4"/>

        <TextBlock Grid.Row="1"
                   Text="Pick solutions to scope the scan and choose which component types to analyze."
                   Style="{StaticResource MaterialDesignBody2TextBlock}"
                   Foreground="{DynamicResource MaterialDesign.Brush.Foreground.Light}"
                   TextWrapping="Wrap" Margin="0,0,0,12"/>

        <!-- Two-column layout: Solutions | Component Types -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <!-- ═══ LEFT: Solutions ═══ -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0">
                    <TextBlock Text="Solutions" DockPanel.Dock="Left"
                               Style="{StaticResource MaterialDesignSubtitle1TextBlock}"
                               VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="All" Click="SelectAll_Click"
                                Style="{StaticResource MaterialDesignFlatButton}"
                                Padding="8,2" Height="28" FontSize="12"/>
                        <Button Content="None" Click="ClearAll_Click"
                                Style="{StaticResource MaterialDesignFlatButton}"
                                Padding="8,2" Height="28" FontSize="12"/>
                    </StackPanel>
                </DockPanel>

                <TextBox Grid.Row="1" x:Name="SearchBox"
                         md:HintAssist.Hint="Search solutions…"
                         md:TextFieldAssist.HasClearButton="True"
                         TextChanged="SearchBox_TextChanged"
                         Margin="0,6,0,8"
                         Padding="8,6"
                         FontSize="13"
                         md:HintAssist.IsFloating="False"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"/>

                <ListView Grid.Row="3" x:Name="SolutionList"
                          BorderThickness="1"
                          BorderBrush="{DynamicResource MaterialDesign.Brush.TextBox.HoverBackground}">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <DockPanel Margin="2,4">
                                <CheckBox DockPanel.Dock="Left"
                                          IsChecked="{Binding IsSelected}"
                                          VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold" FontSize="13">
                                        <Run Text="{Binding FriendlyName, Mode=OneWay}"/>
                                        <Run Text=" " />
                                        <Run Text="{Binding Version, Mode=OneWay}"
                                             Foreground="{DynamicResource MaterialDesign.Brush.Foreground.Light}"
                                             FontSize="11"/>
                                    </TextBlock>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding UniqueName}"
                                                   FontFamily="Cascadia Code,Consolas"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource MaterialDesign.Brush.Foreground.Light}"/>
                                        <TextBlock Text="  ·  " Foreground="Gray"/>
                                        <TextBlock Text="{Binding PublisherName}"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource MaterialDesign.Brush.Foreground.Light}"/>
                                        <TextBlock Margin="6,0,0,0" FontSize="10"
                                                   Foreground="#FFA726"
                                                   Visibility="{Binding IsManaged, Converter={StaticResource BoolToVis}}"
                                                   Text="managed"/>
                                    </StackPanel>
                                </StackPanel>
                            </DockPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>

            <!-- ═══ RIGHT: Component Types ═══ -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Component Types to Scan"
                           Style="{StaticResource MaterialDesignSubtitle1TextBlock}"
                           Margin="0,0,0,6"/>

                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,6">
                    <Button Content="All" Click="SelectAllComponents_Click"
                            Style="{StaticResource MaterialDesignFlatButton}"
                            Padding="8,2" Height="28" FontSize="12"/>
                    <Button Content="None" Click="ClearAllComponents_Click"
                            Style="{StaticResource MaterialDesignFlatButton}"
                            Padding="8,2" Height="28" FontSize="12"/>
                </StackPanel>

                <ListView Grid.Row="2" x:Name="ComponentTypeList"
                          BorderThickness="1"
                          BorderBrush="{DynamicResource MaterialDesign.Brush.TextBox.HoverBackground}">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <DockPanel Margin="4,6">
                                <CheckBox DockPanel.Dock="Left"
                                          IsChecked="{Binding IsSelected}"
                                          VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <StackPanel>
                                    <TextBlock Text="{Binding Label}"
                                               FontWeight="SemiBold" FontSize="13"/>
                                    <TextBlock Text="{Binding Description}"
                                               FontSize="11"
                                               Foreground="{DynamicResource MaterialDesign.Brush.Foreground.Light}"/>
                                </StackPanel>
                            </DockPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Grid>

        <!-- Loading / status -->
        <StackPanel Grid.Row="3" Margin="0,10,0,0">
            <ProgressBar x:Name="LoadingBar" IsIndeterminate="True" Height="4"
                         Visibility="Collapsed"/>
            <TextBlock x:Name="StatusText" Margin="0,4,0,0"
                       Foreground="{DynamicResource MaterialDesign.Brush.Foreground.Light}"/>
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="4" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Scan All (no filter)"
                    Click="ScanAll_Click"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    Height="38" Margin="0,0,8,0"/>
            <Button Content="Scan Selected"
                    Click="ScanSelected_Click"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    Height="38" MinWidth="140"/>
        </StackPanel>
    </Grid>
</Window>
