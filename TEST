// Find the exact element and its real ID
var sg = document.querySelector("[data-control-name='Subgrid_councilAllocations']");
console.log("Element found:", sg);
console.log("Element ID:", sg ? sg.id : "null");
console.log("Element tag:", sg ? sg.tagName : "null");
console.log("Parent ID:", sg ? sg.parentElement.id : "null");

// Find all buttons inside it
if (sg) {
    var buttons = sg.querySelectorAll("button");
    console.log("Total buttons inside:", buttons.length);
    buttons.forEach(function(btn, i) {
        console.log("Button " + i + ":", {
            label: btn.getAttribute("aria-label"),
            title: btn.title,
            dataId: btn.getAttribute("data-id"),
            id: btn.id
        });
    });
}
