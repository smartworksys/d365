// Search by button id which we now know exactly
var btn = document.querySelector("button[aria-label*='New Council Change Allocation']");
console.log("Button found in main doc:", btn != null);

// Search in iframes
function findButton(doc, path) {
    var btn = doc.querySelector("button[aria-label*='New Council Change Allocation']");
    if (btn) {
        console.log("Button found at:", path);
        return;
    }
    var iframes = doc.querySelectorAll("iframe");
    iframes.forEach(function(iframe, i) {
        try {
            var iDoc = iframe.contentDocument || iframe.contentWindow.document;
            findButton(iDoc, path + " > iframe[" + i + "]");
        } catch(e) {
            console.log("Blocked:", path + " > iframe[" + i + "]");
        }
    });
}
findButton(document, "document");
