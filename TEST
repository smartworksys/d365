// Check all iframes on the page
var iframes = document.querySelectorAll("iframe");
console.log("Total iframes found:", iframes.length);
iframes.forEach(function(iframe, i) {
    console.log("Iframe " + i + ":", iframe.id, iframe.name, iframe.src);
});

// Search inside each iframe for the subgrid
var iframes = document.querySelectorAll("iframe");
iframes.forEach(function(iframe, i) {
    try {
        var iframeDoc = iframe.contentDocument || iframe.contentWindow.document;
        var sg = iframeDoc.querySelector("[data-control-name*='council']");
        if (sg) {
            console.log("Found in iframe " + i + ":", sg.getAttribute("data-control-name"));
        } else {
            console.log("Iframe " + i + ": subgrid not found");
        }
    } catch(e) {
        console.log("Iframe " + i + " access error:", e.message);
    }
});
