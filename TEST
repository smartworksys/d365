// ============================================================
// Ribbon Workbench Enable Rule
// ============================================================
//
// SCENARIO:
//   Parent Entity: Change Requests (has kofc_status field)
//   Child Entity:  Allocations (displayed in a subgrid)
//   Goal:          Enable/disable the "New" button on the
//                  Allocations subgrid based on the parent's status.
//                  Button should update immediately on field change.
//
// SETUP IN RIBBON WORKBENCH:
//   1. Open Ribbon Workbench and select the ALLOCATIONS entity.
//   2. Find "AddNewStandard" and "New Record" in the SubGrid ribbon.
//   3. Add an Enable Rule → Custom Rule to each:
//        - Library:       kofc_SubgridButtonRules.js (this file)
//        - Function Name: SubgridButtonRules.isNewAllocationEnabled
//        - Parameters:    Add a CrmParameter → PrimaryControl
//   4. Publish the customization.
//
// REGISTER ON PARENT FORM:
//   5. On the Change Requests form, add an OnLoad event:
//        - Library:       kofc_SubgridButtonRules.js (this file)
//        - Function Name: SubgridButtonRules.refreshRibbonOnStatusChange
//        - Pass execution context as first parameter: YES
// ============================================================

var SubgridButtonRules = (function () {

    // ---- Configuration ----
    var STATUS_FIELD = "kofc_status";
    var ALLOWED_STATUSES = [258510002];
    var SUBGRID_NAME = "Council_Change_Allocations";

    // Store the current enabled state globally so the Enable Rule
    // can read it even if the ribbon framework caches the form context.
    var _cachedIsEnabled = false;

    /**
     * Enable Rule — called by the Ribbon framework.
     */
    function isNewAllocationEnabled(primaryControl) {
        var formContext = null;

        if (primaryControl && primaryControl.getAttribute) {
            formContext = primaryControl;
        } else if (primaryControl && primaryControl.getFormContext) {
            formContext = primaryControl.getFormContext();
        } else {
            formContext = typeof Xrm !== "undefined" && Xrm.Page ? Xrm.Page : null;
        }

        if (formContext && formContext.getAttribute) {
            var statusField = formContext.getAttribute(STATUS_FIELD);
            if (statusField) {
                var statusValue = statusField.getValue();
                _cachedIsEnabled = ALLOWED_STATUSES.indexOf(statusValue) !== -1;
                console.log("Enable Rule: kofc_status =", statusValue, "| enabled =", _cachedIsEnabled);
            } else {
                console.log("Enable Rule: Field '" + STATUS_FIELD + "' not found.");
                _cachedIsEnabled = false;
            }
        } else {
            console.log("Enable Rule: Using cached value =", _cachedIsEnabled);
        }

        return _cachedIsEnabled;
    }

    /**
     * Register on the PARENT form's (Change Requests) OnLoad event.
     */
    function refreshRibbonOnStatusChange(executionContext) {
        var formContext = executionContext.getFormContext();
        var statusField = formContext.getAttribute(STATUS_FIELD);

        if (!statusField) {
            console.log("Ribbon refresh: Field '" + STATUS_FIELD + "' not found.");
            return;
        }

        statusField.addOnChange(function () {
            var newValue = statusField.getValue();
            console.log("Parent status changed to:", newValue, "— refreshing ribbon...");

            // Update cached value immediately
            _cachedIsEnabled = ALLOWED_STATUSES.indexOf(newValue) !== -1;

            // Strategy 1: Refresh the subgrid ribbon directly
            var subgridControl = formContext.getControl(SUBGRID_NAME);
            if (subgridControl && subgridControl.refreshRibbon) {
                subgridControl.refreshRibbon();
                console.log("Called subgridControl.refreshRibbon()");
            }

            // Strategy 2: Refresh the entire form ribbon
            if (formContext.ui && formContext.ui.refreshRibbon) {
                formContext.ui.refreshRibbon();
                console.log("Called formContext.ui.refreshRibbon()");
            }

            // Strategy 3: Delayed retry — sometimes the ribbon framework
            // needs a moment to pick up changes in Unified Interface
            setTimeout(function () {
                console.log("Delayed ribbon refresh...");

                var subgrid = formContext.getControl(SUBGRID_NAME);
                if (subgrid && subgrid.refreshRibbon) {
                    subgrid.refreshRibbon();
                }

                if (formContext.ui && formContext.ui.refreshRibbon) {
                    formContext.ui.refreshRibbon();
                }

                // Strategy 4: Xrm.CommandBar if available (UCI)
                if (typeof Xrm !== "undefined" &&
                    Xrm.CommandBar &&
                    Xrm.CommandBar.requestRender) {
                    Xrm.CommandBar.requestRender();
                    console.log("Called Xrm.CommandBar.requestRender()");
                }
            }, 500);
        });
    }

    return {
        isNewAllocationEnabled: isNewAllocationEnabled,
        refreshRibbonOnStatusChange: refreshRibbonOnStatusChange
    };
})();
