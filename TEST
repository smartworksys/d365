    // ──────────────────────────────────────────────

    public async Task<List<SolutionInfo>> GetSolutionsAsync(CancellationToken ct)
    {
        if (_client is null)
            throw new InvalidOperationException("Not connected to Dataverse.");

        var query = new QueryExpression("solution")
        {
            ColumnSet = new ColumnSet(
                "solutionid", "uniquename", "friendlyname", "version", "ismanaged"),
            Criteria = new FilterExpression(LogicalOperator.And),
            PageInfo = new PagingInfo { Count = 5000, PageNumber = 1 }
        };
        // Exclude the internal "Default" and "Active" solutions — they contain everything
        query.Criteria.AddCondition("uniquename", ConditionOperator.NotEqual, "Default");
        query.Criteria.AddCondition("uniquename", ConditionOperator.NotEqual, "Active");
        query.Criteria.AddCondition("uniquename", ConditionOperator.NotEqual, "Basic");

        var link = query.AddLink("publisher", "publisherid", "publisherid", JoinOperator.LeftOuter);
        link.Columns = new ColumnSet("friendlyname");
        link.EntityAlias = "pub";

        var entities = await ExecuteWithThrottleAsync(
            () => RetrieveAllPagesAsync(query, ct), ct);

        return entities.Entities.Select(e => new SolutionInfo
        {
            SolutionId = e.Id,
            UniqueName = e.GetAttributeValue<string>("uniquename") ?? "",
            FriendlyName = e.GetAttributeValue<string>("friendlyname") ?? "",
            Version = e.GetAttributeValue<string>("version") ?? "",
            IsManaged = e.GetAttributeValue<bool>("ismanaged"),
            PublisherName = (e.GetAttributeValue<AliasedValue>("pub.friendlyname")?.Value as string) ?? ""
        })
        .OrderBy(s => s.FriendlyName)
        .ToList();
    }

    public async Task<SolutionScope> BuildSolutionScopeAsync(
        List<Guid> solutionIds, IProgress<string>? progress, CancellationToken ct)
    {
        var scope = new SolutionScope();
        if (solutionIds.Count == 0) return scope;

        progress?.Report("Loading solution components…");

        var relevantTypes = new[]
        {
            SolutionScope.Types.Workflow,
            SolutionScope.Types.WebResource,
            SolutionScope.Types.SdkMessageProcessingStep,
            SolutionScope.Types.CanvasApp,
            SolutionScope.Types.Sitemap,
            SolutionScope.Types.ConnectionReference,
            SolutionScope.Types.EnvironmentVariableDefinition,
            SolutionScope.Types.EnvironmentVariableValue,
        };

        foreach (var solId in solutionIds)
        {
            ct.ThrowIfCancellationRequested();

            var query = new QueryExpression("solutioncomponent")
            {
                ColumnSet = new ColumnSet("objectid", "componenttype"),
                Criteria = new FilterExpression(LogicalOperator.And),
                PageInfo = new PagingInfo { Count = 5000, PageNumber = 1 }
            };
            query.Criteria.AddCondition("solutionid", ConditionOperator.Equal, solId);

            var entities = await ExecuteWithThrottleAsync(
                () => RetrieveAllPagesAsync(query, ct), ct);

            foreach (var entity in entities.Entities)
            {
                var compType = entity.GetAttributeValue<OptionSetValue>("componenttype")?.Value ?? 0;
                var objectId = entity.GetAttributeValue<Guid>("objectid");

                if (objectId == Guid.Empty || !relevantTypes.Contains(compType))
                    continue;

                if (!scope.ComponentIdsByType.ContainsKey(compType))
                    scope.ComponentIdsByType[compType] = new HashSet<Guid>();
                scope.ComponentIdsByType[compType].Add(objectId);
            }
        }

        var total = scope.ComponentIdsByType.Values.Sum(s => s.Count);
        progress?.Report($"Solution scope built: {total} components across {solutionIds.Count} solution(s).");
        Log.Information("Solution scope: {Count} components from {Solutions} solutions",
            total, solutionIds.Count);

        return scope;
    }

    // ──────────────────────────────────────────────
    //  Analysis
    // ──────────────────────────────────────────────

    public async Task<List<EnvVarAnalysisRow>> AnalyzeAsync(
        SolutionScope? scope, ScanOptions? scanOptions,
        IProgress<string>? progress, CancellationToken ct)
    {
        if (_client is null)
            throw new InvalidOperationException("Not connected to Dataverse.");

        scope ??= new SolutionScope();
        scanOptions ??= new ScanOptions();
        _componentErrors.Clear();
        _scanStatus.Clear();

        progress?.Report("Loading environment variable definitions…");
        var definitions = await ExecuteWithThrottleAsync(
            () => LoadDefinitionsAsync(ct), ct);

        var filteredDefs = scope.IsScoped
            ? definitions.Entities
                .Where(d => scope.Contains(SolutionScope.Types.EnvironmentVariableDefinition, d.Id))
                .ToList()
            : definitions.Entities.ToList();

        progress?.Report($"Found {filteredDefs.Count} environment variable definitions…");

        progress?.Report("Loading environment variable values…");
        var values = await ExecuteWithThrottleAsync(
            () => LoadValuesAsync(ct), ct);

        var valuesByDefId = values.Entities
            .GroupBy(v => v.GetAttributeValue<EntityReference>(
                "environmentvariabledefinitionid")?.Id ?? Guid.Empty)
            .ToDictionary(g => g.Key, g => g.First());

        var schemaNames = filteredDefs
            .Select(d => d.GetAttributeValue<string>("schemaname") ?? "")
            .Where(s => !string.IsNullOrEmpty(s))
            .ToHashSet(StringComparer.OrdinalIgnoreCase);

        var enabledCount = scanOptions.EnabledComponentTypes.Count;
        progress?.Report($"Scanning {enabledCount} component type(s) for {schemaNames.Count} variables…");
        var referenceMap = await ScanAllComponentsAsync(schemaNames, scope, scanOptions, progress, ct);

        progress?.Report("Building analysis results…");
        var results = new List<EnvVarAnalysisRow>();

        foreach (var def in filteredDefs)
        {
            ct.ThrowIfCancellationRequested();

            var schemaName = def.GetAttributeValue<string>("schemaname") ?? "";
            var displayName = def.GetAttributeValue<string>("displayname") ?? schemaName;
            var type = MapType(def.GetAttributeValue<OptionSetValue>("type")?.Value);
            var defaultValue = def.GetAttributeValue<string>("defaultvalue") ?? "";

            string currentValue = "";
            var defId = def.GetAttributeValue<Guid>("environmentvariabledefinitionid");
            if (defId == Guid.Empty)
                defId = def.Id;

            if (valuesByDefId.TryGetValue(defId, out var valEntity))
                currentValue = valEntity.GetAttributeValue<string>("value") ?? "";

            var delta = DetermineStatus(defaultValue, currentValue,
                valuesByDefId.ContainsKey(defId));

            referenceMap.TryGetValue(schemaName, out var refs);

            results.Add(new EnvVarAnalysisRow(
                schemaName, displayName, type,
                defaultValue, currentValue, delta,
                refs ?? new List<ComponentReference>()));
        }

        return results.OrderBy(r => r.DisplayName).ToList();
    }

    private static DeltaStatus DetermineStatus(
        string defaultVal, string currentVal, bool hasValueRow)
    {
        if (!hasValueRow && string.IsNullOrEmpty(defaultVal))
            return DeltaStatus.NoDefault;
        if (!hasValueRow)
            return DeltaStatus.Missing;
        if (string.Equals(defaultVal, currentVal, StringComparison.Ordinal))
            return DeltaStatus.Same;
        return DeltaStatus.Changed;
    }

    private static string MapType(int? typeCode) => typeCode switch
    {
        100000000 => "String",
        100000001 => "Number",
        100000002 => "Boolean",
        100000003 => "JSON",
        100000004 => "Data Source",
        _ => "Unknown"
    };

    private async Task<EntityCollection> LoadDefinitionsAsync(CancellationToken ct)
    {
        var query = new QueryExpression("environmentvariabledefinition")
        {
            ColumnSet = new ColumnSet(
                "environmentvariabledefinitionid", "schemaname", "displayname",
                "description", "type", "defaultvalue", "introducedversion"),
            PageInfo = new PagingInfo { Count = 5000, PageNumber = 1 }
        };
        return await RetrieveAllPagesAsync(query, ct);
    }

    private async Task<EntityCollection> LoadValuesAsync(CancellationToken ct)
    {
        var query = new QueryExpression("environmentvariablevalue")
        {
            ColumnSet = new ColumnSet(
                "environmentvariablevalueid", "environmentvariabledefinitionid",
                "value"),
            PageInfo = new PagingInfo { Count = 5000, PageNumber = 1 }
        };
        return await RetrieveAllPagesAsync(query, ct);
    }

    // ──────────────────────────────────────────────
    //  Aggregated parallel scan (solution-aware)
    // ──────────────────────────────────────────────

    private async Task<Dictionary<string, List<ComponentReference>>> ScanAllComponentsAsync(
        HashSet<string> schemaNames, SolutionScope scope, ScanOptions scanOptions,
        IProgress<string>? progress, CancellationToken ct)
    {
        var map = new ConcurrentDictionary<string, List<ComponentReference>>(
            StringComparer.OrdinalIgnoreCase);

        void Merge(Dictionary<string, List<ComponentReference>> partial)
        {
            foreach (var (key, refs) in partial)
                map.AddOrUpdate(key, _ => new List<ComponentReference>(refs),
                    (_, existing) => { lock (existing) { existing.AddRange(refs); } return existing; });
        }

        var allScans = new (string Key, string Label, Func<Task<Dictionary<string, List<ComponentReference>>>> Scanner)[]
        {
            ("Flows",        "Flows",        () => ScanFlowsAsync(schemaNames, scope, ct)),
            ("CanvasApps",   "Canvas Apps",  () => ScanCanvasAppsAsync(schemaNames, scope, progress, ct)),
            ("WebResources", "Web Resources",() => ScanWebResourcesAsync(schemaNames, scope, ct)),
            ("BusinessRules","Business Rules",() => ScanBusinessRulesAsync(schemaNames, scope, ct)),
            ("Plugins",      "Plugins",      () => ScanPluginsAsync(schemaNames, scope, ct)),
            ("Sitemaps",     "Sitemaps",     () => ScanSitemapsAsync(schemaNames, scope, ct)),
            ("ConnRefs",     "Conn. Refs",   () => ScanConnectionReferencesAsync(schemaNames, scope, ct)),
        };

        var enabledScans = allScans
            .Where(s => scanOptions.IsComponentEnabled(s.Key))
            .ToList();

        var skipped = allScans.Length - enabledScans.Count;
        if (skipped > 0)
            Log.Information("Skipping {Count} disabled component type(s)", skipped);

        var sw = Stopwatch.StartNew();
        var completedCount = 0;
        var totalScans = enabledScans.Count;

        void ReportAggregateProgress(string scanName, string status)
        {
            _scanStatus[scanName] = status;
            var pending = _scanStatus.Where(kv => kv.Value != "done").Select(kv => kv.Key).ToList();
            if (pending.Count == 0)
                progress?.Report("All component scans complete.");
            else
                progress?.Report($"[{completedCount}/{totalScans}] Scanning: {string.Join(", ", pending)} ({sw.Elapsed.TotalSeconds:F0}s)");
        }

        async Task RunScan(string label, Func<Task<Dictionary<string, List<ComponentReference>>>> scanner)
        {
            try
            {
                ReportAggregateProgress(label, "running");
                var partial = await scanner();
                Merge(partial);
            }
            catch (Exception ex)
            {
                _componentErrors.Add($"{label}: {ex.Message}");
                Log.Warning(ex, "Component scan failed for {ComponentType}", label);
            }
            finally
            {
                Interlocked.Increment(ref completedCount);
                ReportAggregateProgress(label, "done");
            }
        }

        var tasks = enabledScans
            .Select(s => RunScan(s.Label, s.Scanner))
            .ToArray();

        await Task.WhenAll(tasks);
        sw.Stop();
        Log.Information("Component scans completed in {Elapsed}s ({Enabled}/{Total} types enabled)",
            sw.Elapsed.TotalSeconds, enabledScans.Count, allScans.Length);

        return map.ToDictionary(kv => kv.Key, kv => kv.Value, StringComparer.OrdinalIgnoreCase);
    }

    // ──────────────────────────────────────────────
    //  Server-side scope filtering helper
    // ──────────────────────────────────────────────

    /// <summary>
    /// When scoped, adds an IN condition on the primary key so Dataverse only
    /// returns the rows that belong to the selected solutions.
    /// Returns false if scoped but no IDs exist for this component type (nothing to scan).
    /// </summary>
    private static bool ApplyScopeFilter(
        QueryExpression query, string primaryKeyField,
        SolutionScope scope, int componentType)
    {
        if (!scope.IsScoped) return true;

        if (!scope.ComponentIdsByType.TryGetValue(componentType, out var ids) || ids.Count == 0)
            return false;

        var idValues = ids.Cast<object>().ToArray();
        query.Criteria.AddCondition(primaryKeyField, ConditionOperator.In, idValues);
        return true;
    }

