/*
 * KOFC EApp SSO - Boomi call from a Dynamics 365 command bar button.
 *
 * Wire-up (Command designer / ribbon):
 *   Function name:  KOFC.Eapp.callBoomi
 *   Library:        kofc_eappBoomiCall.js
 *   Parameter:      PrimaryControl   (pass the form context)
 *
 * Prerequisites (already uploaded as web resources):
 *   - kofc_msal-browser.min.js   (MSAL library)
 *   - kofc_eappauthcallback.html (MSAL redirect URI page; must be registered in Entra as an SPA redirect URI)
 *
 * SECURITY NOTE: x-api-key lives in client-side script and is visible to any form user.
 * Prefer having Boomi authorize on the user's bearer token instead of a shared key. If a key
 * is required, treat it as low-sensitivity and rotate it. Ideally move CONFIG values into a
 * Dataverse environment variable and read them via Xrm.WebApi rather than hard-coding here.
 */
var KOFC = KOFC || {};

KOFC.Eapp = (function () {
    "use strict";

    var CONFIG = {
        tenantId: "<TENANT_ID>",
        clientId: "<SPA_CLIENT_ID>",
        apiAppId: "<FUNCTION_API_APP_ID>",
        scope: "access_as_user",
        boomiUrl: "https://<boomi-host>/ws/rest/YourProcess",
        httpMethod: "POST",
        apiKey: "<X_API_KEY>",
        // Served + Entra-registered redirect page. Must match Entra character-for-character
        // (case-sensitive). Leave null to use the default below.
        redirectUri: null,
        redirectWebResource: "kofc_eappauthcallback.html",
        msalWebResourcePath: "/WebResources/kofc_msal-browser.min.js",
        // false = never show popup/redirect UI; fails with a clear message if silent auth cannot complete.
        // Set true only for first-time user consent troubleshooting.
        allowInteractive: false
    };

    var msalApp = null;
    var msalLoad = null;

    function origin() {
        return window.location.origin;
    }

    function redirectUri() {
        return CONFIG.redirectUri
            || (origin() + "/WebResources/" + CONFIG.redirectWebResource);
    }

    var MSAL_CFG_KEY = "kofc_eapp_msal_cfg";

    function persistMsalConfig() {
        try {
            localStorage.setItem(MSAL_CFG_KEY, JSON.stringify({
                clientId: CONFIG.clientId,
                tenantId: CONFIG.tenantId,
                redirectUri: redirectUri()
            }));
        } catch (e) {
            // non-fatal; callback may not complete redirect without this
        }
    }

    function scopes() {
        return ["api://" + CONFIG.apiAppId + "/" + CONFIG.scope];
    }

    function stripBraces(value) {
        return (value || "").replace(/[{}]/g, "").trim();
    }

    function loadMsal() {
        if (typeof msal !== "undefined") {
            return Promise.resolve();
        }
        if (msalLoad) {
            return msalLoad;
        }
        msalLoad = new Promise(function (resolve, reject) {
            var s = document.createElement("script");
            s.src = origin() + CONFIG.msalWebResourcePath;
            s.onload = function () {
                if (typeof msal !== "undefined") {
                    resolve();
                } else {
                    reject(new Error("MSAL loaded but global 'msal' is undefined."));
                }
            };
            s.onerror = function () {
                reject(new Error("Failed to load MSAL web resource: " + s.src));
            };
            document.head.appendChild(s);
        });
        return msalLoad;
    }

    async function initMsal() {
        if (msalApp) {
            return msalApp;
        }
        await loadMsal();
        msalApp = new msal.PublicClientApplication({
            auth: {
                clientId: CONFIG.clientId,
                authority: "https://login.microsoftonline.com/" + CONFIG.tenantId,
                redirectUri: redirectUri()
            },
            cache: {
                cacheLocation: "localStorage",
                storeAuthStateInCookie: true
            }
        });
        await msalApp.initialize();
        persistMsalConfig();
        // Complete any in-flight redirect (harmless if none).
        await msalApp.handleRedirectPromise();
        return msalApp;
    }

    function pickAccount(accounts, loginHint) {
        if (!accounts || accounts.length === 0) {
            return null;
        }
        if (loginHint) {
            var hint = loginHint.toLowerCase();
            for (var i = 0; i < accounts.length; i++) {
                var username = (accounts[i].username || "").toLowerCase();
                if (username === hint) {
                    return accounts[i];
                }
            }
        }
        return accounts[0];
    }

    async function getToken(loginHint) {
        await initMsal();

        var scopeList = scopes();
        var silentReq = {
            scopes: scopeList,
            prompt: "none"
        };

        // 1) Hidden iframe SSO — no visible UI when the user is already signed into Entra (via D365).
        if (loginHint) {
            try {
                var sso = await msalApp.ssoSilent({
                    scopes: scopeList,
                    loginHint: loginHint,
                    prompt: "none",
                    redirectUri: redirectUri()
                });
                return sso.accessToken;
            } catch (e) {
                // fall through
            }
        }

        // 2) Silent refresh from MSAL cache (also no UI).
        var accounts = msalApp.getAllAccounts();
        var account = pickAccount(accounts, loginHint);
        if (account) {
            try {
                silentReq.account = account;
                var silent = await msalApp.acquireTokenSilent(silentReq);
                return silent.accessToken;
            } catch (e) {
                // fall through
            }
        }

        if (!CONFIG.allowInteractive) {
            throw new Error(
                "Silent sign-in failed. Ensure admin consent is granted for api://"
                + CONFIG.apiAppId + "/" + CONFIG.scope
                + ", the user has signed into this org once, and third-party cookies are not blocked. "
                + "For a one-time consent prompt, set CONFIG.allowInteractive = true."
            );
        }

        // 3) Interactive popup — only when allowInteractive is true (first consent / troubleshooting).
        var popupReq = { scopes: scopeList, prompt: "select_account" };
        if (loginHint) {
            popupReq.loginHint = loginHint;
        }
        var popup = await msalApp.acquireTokenPopup(popupReq);
        return popup.accessToken;
    }

    function buildUrl(userId, oppId, boomiUrl) {
        var base = boomiUrl || CONFIG.boomiUrl;
        var qs = "userId=" + encodeURIComponent(userId);
        if (oppId) {
            qs += "&oppID=" + encodeURIComponent(oppId);
        }
        return base + (base.indexOf("?") >= 0 ? "&" : "?") + qs;
    }

    async function callBoomiApi(token, userId, oppId, boomiUrl) {
        var method = (CONFIG.httpMethod || "POST").toUpperCase();
        var options = {
            method: method,
            headers: {
                "Authorization": "Bearer " + token,
                "x-api-key": CONFIG.apiKey,
                "Accept": "text/plain"
            }
        };
        if (method !== "GET" && method !== "HEAD") {
            options.headers["Content-Type"] = "application/json";
            options.body = JSON.stringify({ userId: userId, oppID: oppId || undefined });
        }

        var response = await fetch(buildUrl(userId, oppId, boomiUrl), options);
        var body = await response.text();
        if (!response.ok) {
            throw new Error("Boomi returned " + response.status + ": " + body);
        }
        return { status: response.status, body: body };
    }

    function deriveLoginHint() {
        try {
            var loginHint = Xrm.Utility.getGlobalContext().userSettings.userName;
            return (loginHint && loginHint.indexOf("@") >= 0) ? loginHint : null;
        } catch (e) {
            return null;
        }
    }

    // Public: acquire the delegated user access token (ssoSilent -> silent cache; popup only if allowInteractive).
    async function getAccessToken() {
        return getToken(deriveLoginHint());
    }

    // Public: acquire a token and call Boomi at the given URL, returning the raw response body.
    // Use this from existing code that handles the response itself (e.g. opens the EApp URL).
    async function callBoomiRaw(boomiUrl, userId, oppId) {
        var token = await getToken(deriveLoginHint());
        var result = await callBoomiApi(
            token,
            stripBraces(userId),
            stripBraces(oppId),
            boomiUrl || CONFIG.boomiUrl
        );
        return result.body;
    }

    // Entry point for the command bar button. Pass PrimaryControl as the parameter.
    async function callBoomi(primaryControl) {
        try {
            var gctx = Xrm.Utility.getGlobalContext();
            var userId = stripBraces(gctx.userSettings.userId);
            var loginHint = deriveLoginHint();

            var oppId = "";
            if (primaryControl && primaryControl.data && primaryControl.data.entity
                && primaryControl.data.entity.getEntityName
                && primaryControl.data.entity.getEntityName() === "opportunity") {
                oppId = stripBraces(primaryControl.data.entity.getId());
            }

            if (!userId) {
                throw new Error("Could not determine the current user's systemuserid.");
            }

            var token = await getToken(loginHint);
            var result = await callBoomiApi(token, userId, oppId);

            await Xrm.Navigation.openAlertDialog({
                title: "EApp SSO",
                text: "Boomi call succeeded (HTTP " + result.status + ")."
            });
            return result.body;
        } catch (e) {
            var message = (e && e.message) ? e.message : String(e);
            if (Xrm.Navigation.openErrorDialog) {
                Xrm.Navigation.openErrorDialog({ message: "Boomi call failed: " + message });
            } else {
                Xrm.Navigation.openAlertDialog({ title: "EApp SSO - Error", text: message });
            }
        }
    }

    return {
        callBoomi: callBoomi,
        getAccessToken: getAccessToken,
        callBoomiRaw: callBoomiRaw
    };
})();


<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Auth Callback</title>
    <!--
      MSAL redirect URI for kofc_eappBoomiCall.js (ssoSilent hidden iframe + optional interactive fallback).

      Silent flow: loaded inside a hidden iframe — must stay blank (no scripts, no UI).
      Interactive flow: only when CONFIG.allowInteractive = true; processes ?code= via handleRedirectPromise.

      Register in Entra (case-sensitive):
        https://<org>.crm.dynamics.com/WebResources/kofc_eappauthcallback.html
    -->
</head>
<body>
    <script>
        (function () {
            "use strict";

            // ssoSilent hidden iframe — parent MSAL reads the response; do not run any logic here.
            if (window.self !== window.top) {
                return;
            }

            var hasAuthResponse = window.location.hash.indexOf("code=") >= 0
                || window.location.hash.indexOf("error=") >= 0
                || window.location.search.indexOf("code=") >= 0
                || window.location.search.indexOf("error=") >= 0;

            // No auth response and not in iframe — user opened this page directly; stay blank.
            if (!hasAuthResponse) {
                return;
            }

            // Interactive fallback only (allowInteractive = true). Load MSAL dynamically.
            var CFG_KEY = "kofc_eapp_msal_cfg";

            function readCfg() {
                try {
                    var raw = localStorage.getItem(CFG_KEY);
                    return raw ? JSON.parse(raw) : null;
                } catch (e) {
                    return null;
                }
            }

            function loadMsal() {
                return new Promise(function (resolve, reject) {
                    if (typeof msal !== "undefined") {
                        resolve();
                        return;
                    }
                    var s = document.createElement("script");
                    s.src = window.location.origin + "/WebResources/kofc_msal-browser.min.js";
                    s.onload = function () {
                        if (typeof msal !== "undefined") {
                            resolve();
                        } else {
                            reject(new Error("MSAL failed to load."));
                        }
                    };
                    s.onerror = function () {
                        reject(new Error("MSAL web resource not found."));
                    };
                    document.head.appendChild(s);
                });
            }

            async function run() {
                var cfg = readCfg();
                if (!cfg || !cfg.clientId || !cfg.tenantId || !cfg.redirectUri) {
                    return;
                }

                try {
                    await loadMsal();
                    var pca = new msal.PublicClientApplication({
                        auth: {
                            clientId: cfg.clientId,
                            authority: "https://login.microsoftonline.com/" + cfg.tenantId,
                            redirectUri: cfg.redirectUri
                        },
                        cache: {
                            cacheLocation: "localStorage",
                            storeAuthStateInCookie: true
                        }
                    });

                    await pca.initialize();
                    await pca.handleRedirectPromise();
                } catch (e) {
                    // Opener handles errors; keep page blank.
                }
            }

            run();
        })();
    </script>
</body>
</html>
