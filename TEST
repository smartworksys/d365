<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Boomi Integration Validator</title>
    <style>
        body {
            font-family: Segoe UI, Arial, sans-serif;
            margin: 16px;
            max-width: 900px;
        }

        h1 {
            font-size: 1.25rem;
            margin-bottom: 8px;
        }

        fieldset {
            border: 1px solid #ccc;
            margin-bottom: 12px;
            padding: 12px;
        }

        legend {
            font-weight: 600;
        }

        label {
            display: block;
            margin: 8px 0 4px;
            font-size: 0.9rem;
        }

        input[type="text"],
        input[type="password"] {
            width: 100%;
            box-sizing: border-box;
            padding: 6px 8px;
        }

        button {
            margin-right: 8px;
            margin-top: 8px;
            padding: 8px 14px;
            cursor: pointer;
        }

        pre {
            background: #f4f4f4;
            border: 1px solid #ddd;
            padding: 10px;
            white-space: pre-wrap;
            word-break: break-word;
            max-height: 320px;
            overflow: auto;
        }

        .ok {
            color: #107c10;
        }

        .err {
            color: #a4262c;
        }

        .hint {
            color: #605e5c;
            font-size: 0.85rem;
        }
    </style>

    <!--
      Upload msal-browser.min.js as web resource kofc_msal-browser.min.js
      and use that path if your org blocks CDN scripts.
    -->
    <script src="https://alcdn.msauth.net/browser/2.38.3/js/msal-browser.min.js"></script>
</head>
<body>
    <h1>Boomi Integration Validator</h1>
    <p class="hint">
        Validate MSAL token acquisition and the Dynamics → Boomi → Function App path.
        Open from Dynamics as a web resource so <code>Xrm</code> can prefill user context.
    </p>

    <fieldset>
        <legend>Config</legend>
        <label for="tenantId">Tenant ID</label>
        <input id="tenantId" type="text" placeholder="00000000-0000-0000-0000-000000000000" />

        <label for="clientId">SPA Client ID</label>
        <input id="clientId" type="text" placeholder="SPA app registration client ID" />

        <label for="apiAppId">Function API App ID (for scope)</label>
        <input id="apiAppId" type="text" placeholder="Function App API app registration ID" />

        <label for="boomiUrl">Boomi URL (no query string)</label>
        <input id="boomiUrl" type="text" placeholder="https://your-boomi-host/ws/rest/YourProcess" />

        <label for="boomiApiKey">Boomi API key (x-api-key)</label>
        <input id="boomiApiKey" type="password" placeholder="Boomi API key" autocomplete="off" />
    </fieldset>

    <fieldset>
        <legend>Request params</legend>
        <label for="userId">userId (Dataverse systemuserid)</label>
        <input id="userId" type="text" placeholder="Auto-filled from D365 when available" />

        <label for="oppId">oppID (optional)</label>
        <input id="oppId" type="text" placeholder="Opportunity GUID" />
    </fieldset>

    <button id="btnToken" type="button">1. Validate token</button>
    <button id="btnCall" type="button">2. Validate full integration</button>
    <button id="btnClear" type="button">Clear log</button>

    <h2>Validation log</h2>
    <pre id="log"></pre>

    <script>
        (function () {
            "use strict";

            var VALIDATOR_NAME = "Boomi Integration Validator";
            var logEl = document.getElementById("log");
            var msalApp = null;

            function log(message, isError) {
                var line = "[" + new Date().toLocaleTimeString() + "] " + message;
                logEl.textContent += line + "\n";
                logEl.className = isError ? "err" : "";
                console.log(message);
            }

            function getConfig() {
                return {
                    tenantId: document.getElementById("tenantId").value.trim(),
                    clientId: document.getElementById("clientId").value.trim(),
                    apiAppId: document.getElementById("apiAppId").value.trim(),
                    boomiUrl: document.getElementById("boomiUrl").value.trim(),
                    boomiApiKey: document.getElementById("boomiApiKey").value.trim(),
                    userId: document.getElementById("userId").value.trim(),
                    oppId: document.getElementById("oppId").value.trim()
                };
            }

            function validateConfig(cfg, requireBoomi) {
                if (!cfg.tenantId || !cfg.clientId || !cfg.apiAppId) {
                    throw new Error("Tenant ID, SPA Client ID, and Function API App ID are required.");
                }
                if (requireBoomi && !cfg.boomiUrl) {
                    throw new Error("Boomi URL is required.");
                }
                if (requireBoomi && !cfg.userId) {
                    throw new Error("userId is required.");
                }
                if (requireBoomi && !cfg.boomiApiKey) {
                    throw new Error("Boomi API key (x-api-key) is required.");
                }
            }

            function getScopes(apiAppId) {
                return [
                    "api://" + apiAppId + "/Contact.Read",
                    "api://" + apiAppId + "/Opportunity.Read"
                ];
            }

            async function initializeMsal(cfg) {
                if (typeof msal === "undefined") {
                    throw new Error("MSAL library not loaded. Upload kofc_msal-browser.min.js as a web resource if CDN is blocked.");
                }

                if (!msalApp) {
                    msalApp = new msal.PublicClientApplication({
                        auth: {
                            clientId: cfg.clientId,
                            authority: "https://login.microsoftonline.com/" + cfg.tenantId,
                            redirectUri: window.location.origin
                        },
                        cache: {
                            cacheLocation: "sessionStorage",
                            storeAuthStateInCookie: true
                        }
                    });
                    await msalApp.initialize();
                }

                return msalApp;
            }

            async function acquireToken(cfg) {
                var app = await initializeMsal(cfg);
                var request = { scopes: getScopes(cfg.apiAppId) };
                var accounts = app.getAllAccounts();

                if (accounts.length > 0) {
                    try {
                        var silent = await app.acquireTokenSilent({
                            scopes: request.scopes,
                            account: accounts[0]
                        });
                        return silent.accessToken;
                    } catch (silentError) {
                        log("Silent token failed, opening login popup...", false);
                    }
                }

                var popup = await app.loginPopup(request);
                return popup.accessToken;
            }

            function decodeJwtPayload(token) {
                try {
                    var parts = token.split(".");
                    if (parts.length < 2) {
                        return null;
                    }
                    var json = atob(parts[1].replace(/-/g, "+").replace(/_/g, "/"));
                    return JSON.parse(json);
                } catch (e) {
                    return null;
                }
            }

            async function callBoomi(cfg, token) {
                var query = new URLSearchParams({ userId: cfg.userId });
                if (cfg.oppId) {
                    query.append("oppID", cfg.oppId);
                }

                var url = cfg.boomiUrl + (cfg.boomiUrl.indexOf("?") >= 0 ? "&" : "?") + query.toString();
                log("Calling Boomi: " + url, false);
                log("Sending headers: Authorization (Bearer), x-api-key", false);

                var response = await fetch(url, {
                    method: "GET",
                    headers: {
                        "Authorization": "Bearer " + token,
                        "x-api-key": cfg.boomiApiKey,
                        "Accept": "text/plain"
                    }
                });

                var body = await response.text();

                if (!response.ok) {
                    throw new Error("Boomi returned " + response.status + ": " + body);
                }

                return {
                    status: response.status,
                    body: body
                };
            }

            function prefillFromDynamics() {
                log(VALIDATOR_NAME + " ready.", false);

                try {
                    if (typeof Xrm !== "undefined" && Xrm.Utility && Xrm.Utility.getGlobalContext) {
                        var ctx = Xrm.Utility.getGlobalContext();
                        var currentUserId = ctx.userSettings.userId.replace(/[{}]/g, "");
                        document.getElementById("userId").value = currentUserId;
                        log("Prefilled userId from D365: " + currentUserId, false);

                        if (typeof Xrm.Page !== "undefined" && Xrm.Page.data && Xrm.Page.data.entity) {
                            var entityName = Xrm.Page.data.entity.getEntityName();
                            if (entityName === "opportunity") {
                                var oppId = Xrm.Page.data.entity.getId().replace(/[{}]/g, "");
                                document.getElementById("oppId").value = oppId;
                                log("Prefilled oppID from Opportunity form: " + oppId, false);
                            }
                        }
                    } else {
                        log("Xrm not available. Enter userId manually or open from Dynamics.", false);
                    }
                } catch (e) {
                    log("Could not prefill from D365: " + e.message, true);
                }
            }

            document.getElementById("btnToken").addEventListener("click", async function () {
                try {
                    var cfg = getConfig();
                    validateConfig(cfg, false);
                    log("Validating MSAL token acquisition...", false);

                    var token = await acquireToken(cfg);
                    var claims = decodeJwtPayload(token);

                    log("Token validation passed.", false);
                    if (claims) {
                        log("aud: " + (claims.aud || ""), false);
                        log("scp: " + (claims.scp || claims.roles || ""), false);
                        log("oid: " + (claims.oid || ""), false);
                        log("appid/azp: " + (claims.appid || claims.azp || ""), false);
                    }
                    log("Token (first 40 chars): " + token.substring(0, 40) + "...", false);
                } catch (e) {
                    log("Token validation failed: " + (e.message || e), true);
                }
            });

            document.getElementById("btnCall").addEventListener("click", async function () {
                try {
                    var cfg = getConfig();
                    validateConfig(cfg, true);
                    log("Starting full integration validation...", false);

                    var token = await acquireToken(cfg);
                    var claims = decodeJwtPayload(token);
                    log("Token acquired. scp/roles: " + (claims ? (claims.scp || claims.roles || "") : "n/a"), false);

                    var result = await callBoomi(cfg, token);
                    log("Boomi integration validation passed. HTTP " + result.status, false);
                    log("Response (first 120 chars): " + result.body.substring(0, 120) + "...", false);
                    log(VALIDATOR_NAME + " completed successfully.", false);
                } catch (e) {
                    log("Integration validation failed: " + (e.message || e), true);
                }
            });

            document.getElementById("btnClear").addEventListener("click", function () {
                logEl.textContent = "";
                logEl.className = "";
            });

            prefillFromDynamics();
        })();
    </script>
</body>
</html>
