// Run this in browser console to find the exact button
var subgridEl = document.getElementById("subgrid_councilAllocations");
console.log("Subgrid found:", subgridEl);

if (subgridEl) {
    var allButtons = subgridEl.querySelectorAll("button");
    console.log("Total buttons found:", allButtons.length);
    allButtons.forEach(function(btn, index) {
        console.log("Button " + index + ":", {
            id: btn.id,
            title: btn.title,
            ariaLabel: btn.getAttribute("aria-label"),
            dataId: btn.getAttribute("data-id"),
            text: btn.innerText,
            disabled: btn.disabled
        });
    });
}


// Check ALL subgrids on the form
var allSubgrids = document.querySelectorAll("[data-control-name]");
allSubgrids.forEach(function(sg) {
    console.log("Subgrid control name:", sg.getAttribute("data-control-name"));
});
