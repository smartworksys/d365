setTimeout(function() {
    function searchAllDocuments() {
        function searchIframes(doc, level) {
            var iframes = doc.querySelectorAll("iframe");
            iframes.forEach(function(iframe, i) {
                try {
                    var iDoc = iframe.contentDocument || iframe.contentWindow.document;
                    var controls = iDoc.querySelectorAll("[data-control-name]");
                    console.log("Iframe " + i + " level " + level + " controls:", controls.length);
                    controls.forEach(function(c) {
                        console.log("  Control:", c.getAttribute("data-control-name"));
                    });
                    // Search nested iframes
                    searchIframes(iDoc, level + 1);
                } catch(e) {
                    console.log("Iframe " + i + " level " + level + " blocked:", e.message);
                }
            });
        }
        searchIframes(document, 0);
    }
    searchAllDocuments();
}, 5000);
