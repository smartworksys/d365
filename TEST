using System.Windows;
using System.Windows.Controls;
using D365EnvAnalyzer.Services;
using D365EnvAnalyzer.ViewModels;

namespace D365EnvAnalyzer.Views;

public partial class ConnectWindow : Window
{
    private readonly ConnectViewModel _vm;
    private readonly DataverseService _service;

    public ConnectWindow()
    {
        InitializeComponent();

        _service = new DataverseService();
        _vm = new ConnectViewModel(_service);
        DataContext = _vm;

        Closed += OnClosed;
    }

    private void OnClosed(object? sender, EventArgs e)
    {
        if (DialogResult == true)
        {
            var mainWindow = new MainWindow(_service);
            Application.Current.MainWindow = mainWindow;
            mainWindow.Show();
        }
    }

    private void PasswordBox_PasswordChanged(object sender, RoutedEventArgs e)
    {
        if (sender is PasswordBox pb)
            _vm.ClientSecret = pb.Password;
    }
}
