// Wait 3 seconds then check
setTimeout(function() {
    var all = document.querySelectorAll("[data-control-name]");
    console.log("Total controls found:", all.length);
    all.forEach(function(el) {
        console.log("Control:", el.getAttribute("data-control-name"));
    });
}, 3000);

// Search entire DOM for anything with 'council' or 'allocation'
setTimeout(function() {
    var all = document.querySelectorAll("*");
    all.forEach(function(el) {
        var attrs = el.attributes;
        for (var i = 0; i < attrs.length; i++) {
            if (attrs[i].value && attrs[i].value.toLowerCase().includes("council")) {
                console.log("Found:", el.tagName, attrs[i].name + "=" + attrs[i].value);
            }
        }
    });
}, 3000);
