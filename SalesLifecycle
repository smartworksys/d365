    async function init() {

        try {

            hideError();
            showLoader();
            setLoadingMessage("Loading policy context...");

            const ctx = getContext();

            console.log("Context:", ctx);

            if (!ctx.recordId) {
                throw new Error("Record Id missing");
            }

            setLoadingMessage("Retrieving policy record...");

            const record =
                await getPolicyRecord(
                    ctx.entityName,
                    ctx.recordId
                );

            if (!record) {
                throw new Error("Unable to retrieve policy record");
            }

            const isValid =
                await validateRecord(record);

            if (!isValid) {
                hideLoader();
                return;
            }

            const policyNo = record.kofc_policynumber;
            const sourceName = record.kofc_sourcename;
            const issueCountry =
                record["kofc_issuecountry@OData.Community.Display.V1.FormattedValue"];
            const policyClassification =
                record["kofc_policyclassification@OData.Community.Display.V1.FormattedValue"];

            applySectionVisibility(sourceName, policyClassification);

            console.log("Policy Number:", policyNo);
            console.log("Source:", sourceName);
            console.log("Issue Country:", issueCountry);
            console.log("Policy Classification:", policyClassification);

            setLoadingMessage("Calling Policy Non-Header API service...");

            const data =
                await fetchPolicyData(
                    policyNo,
                    sourceName,
                    issueCountry,
                    policyClassification
                );

            if (!data) {
                throw new Error("No data returned from API");
            }

            if (data.ERROR) {
                throw new Error(String(data.ERROR));
            }

            if (!data.NonHeader?.PolicyNumber) {
                throw new Error("Response contained no data.");
            }

            setLoadingMessage("Rendering data...");
            bind(data);
            scheduleIframeResize();

        } catch (e) {

            console.error("Init Error:", e);

            showError(
                e.message || "Failed to load policy data."
            );

        } finally {

            if (loaderVisible) {
                hideLoaderWithMinimumDelay(300);
            } else {
                scheduleIframeResize();
            }
        }
    }

    if (typeof window !== "undefined") {
        window.addEventListener("load", function () {
            if (!loaderVisible) {
                scheduleIframeResize();
            }
        });
        window.addEventListener("resize", scheduleIframeResize);
    }

    return {
        init: init,
        retry: retry,
        resize: scheduleIframeResize
    };

