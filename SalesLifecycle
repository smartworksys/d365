    function looksLikeEmail(value) {

        return (
            typeof value === "string" &&
            value.indexOf("@") > -1 &&
            value.indexOf("\\") === -1
        );
    }

    function extractWindowsLoginName(value) {

        if (!value || typeof value !== "string") {
            return "";
        }

        value = value.trim();

        if (value.indexOf("\\") > -1) {
            return value.split("\\").pop();
        }

        if (value.indexOf("@") > -1) {
            return value.split("@")[0];
        }

        return value;
    }

    async function getWindowsUserLoginName() {

        try {

            const ctx =
                parent.Xrm.Utility.getGlobalContext();

            const settingUserName =
                (ctx.userSettings.userName || "").trim();

            let domainname = "";

            const userId =
                (ctx.userSettings.userId || "")
                    .replace(/[{}]/g, "");

            if (userId) {

                const user =
                    await parent.Xrm.WebApi.retrieveRecord(
                        "systemuser",
                        userId,
                        "?$select=domainname"
                    );

                domainname = (user.domainname || "").trim();
            }

            console.log("User identity fields:", {
                domainname: domainname,
                userName: settingUserName
            });

            if (domainname.indexOf("\\") > -1) {
                return domainname;
            }

            if (settingUserName.indexOf("\\") > -1) {
                return settingUserName;
            }

            if (domainname && !looksLikeEmail(domainname)) {
                return domainname;
            }

            if (settingUserName && !looksLikeEmail(settingUserName)) {
                return settingUserName;
            }

            const loginFromDomain =
                extractWindowsLoginName(domainname);

            if (loginFromDomain) {
                return loginFromDomain;
            }

            const loginFromSetting =
                extractWindowsLoginName(settingUserName);

            if (loginFromSetting) {
                return loginFromSetting;
            }

            return "system";

        } catch (e) {

            console.warn("Unable to retrieve Windows login name:", e);

            try {

                const settingUserName =
                    parent.Xrm.Utility
                        .getGlobalContext()
                        .userSettings
                        .userName || "";

                return (
                    extractWindowsLoginName(settingUserName) ||
                    "system"
                );

            } catch (innerError) {
                return "system";
            }
        }
    }

