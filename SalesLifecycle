    function getContext() {

        let recordId = null;
        let entityName = "kofc_policy";

        try {

            const params = new URLSearchParams(window.location.search);

            recordId =
                params.get("id") ||
                params.get("data");

            if (parent && parent.Xrm) {

                const q =
                    parent.Xrm.Utility
                        .getGlobalContext()
                        .getQueryStringParameters();

