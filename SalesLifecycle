
var PolicyDetails = (function () {

    let loaderVisible = false;
    let loaderShownAt = 0;

    function showLoader() {

        loaderVisible = true;
        loaderShownAt = Date.now();

        const el = document.getElementById("loader");

        if (el) {
            el.style.display = "flex";
            el.setAttribute("aria-hidden", "false");
        }

        document.body.classList.add("is-loading");

        // Force paint before async work so loader is visible during API calls.
        void document.body.offsetHeight;
    }

    function hideLoader() {

        loaderVisible = false;

        const el = document.getElementById("loader");

        if (el) {
            el.style.display = "none";
            el.setAttribute("aria-hidden", "true");
        }

        document.body.classList.remove("is-loading");
    }

    function hideLoaderWithMinimumDelay(minVisibleMs) {

        const elapsed = Date.now() - loaderShownAt;
        const delay = Math.max(0, (minVisibleMs || 300) - elapsed);

        setTimeout(function () {
            hideLoader();
            scheduleIframeResize();
        }, delay);
    }

    function setLoadingMessage(message) {
        const el = document.getElementById("loadingText");
        if (el) el.innerText = message || "Loading data...";
    }

    function showError(message) {
        const banner = document.getElementById("errorBanner");
        const msg = document.getElementById("errorMessage");

        if (msg) {
            msg.innerText = message || "Failed to load policy data.";
        }

        if (banner) {
            banner.style.display = "flex";
        }
    }

    function hideError() {
        const banner = document.getElementById("errorBanner");
        if (banner) {
            banner.style.display = "none";
        }
    }

    function getDocumentHeight() {

        return Math.max(
            document.body.scrollHeight,
            document.documentElement.scrollHeight,
            document.body.offsetHeight,
            document.documentElement.offsetHeight
        );
    }

    function resizeParentIframe() {

        if (loaderVisible) {
            return;
        }

        try {

            const height = getDocumentHeight();

            if (window.frameElement) {
                window.frameElement.style.height = (height + 16) + "px";
                window.frameElement.style.overflow = "visible";
                window.frameElement.removeAttribute("scrolling");
            }

        } catch (e) {
            console.warn("Unable to resize parent iframe:", e);
        }
    }

    function scheduleIframeResize() {

        resizeParentIframe();

        setTimeout(resizeParentIframe, 100);
        setTimeout(resizeParentIframe, 400);
        setTimeout(resizeParentIframe, 1000);
    }

    function retry() {
        hideError();
        init();
    }

    function getContext() {

        let recordId = null;
        let entityName = "kofc_policy";

        try {

            const params = new URLSearchParams(window.location.search);

            recordId =
                params.get("id") ||
                params.get("data");

            if (parent && parent.Xrm) {

                const q =
                    parent.Xrm.Utility
                        .getGlobalContext()
                        .getQueryStringParameters();

                recordId = recordId || q.id;
                entityName = q.etn || entityName;
            }

        } catch (e) {
            console.error("Context Error:", e);
        }

        if (recordId) {
            recordId = recordId.replace(/[{}]/g, "");
        }

        return {
            recordId: recordId,
            entityName: entityName
        };
    }

    async function getPolicyRecord(entityName, recordId) {

        try {

            const query =
                "?$select=" +
                [
                    "kofc_policynumber",
                    "kofc_policyclassification",
                    "kofc_sourcename",
                    "kofc_issuecountry"
                ].join(",");

            const record =
                await parent.Xrm.WebApi.retrieveRecord(
                    entityName,
                    recordId,
                    query
                );

            console.log("Policy Record:", record);

            return record;

        } catch (e) {

            console.error("Retrieve Record Error:", e);

            return null;
        }
    }

    async function validateRecord(record) {

        const missingFields = [];

        const policyNumber =
            record?.kofc_policynumber;

        const sourceSystem =
            record?.kofc_sourcename;

        const issueCountry =
            record["kofc_issuecountry@OData.Community.Display.V1.FormattedValue"];

        const policyClassification =
            record["kofc_policyclassification@OData.Community.Display.V1.FormattedValue"];

        const allowedValues = [
            "Ingenium",
            "DI",
            "LTC",
            "L70",
            "Life 70"
        ];

        if (!policyNumber) {
            missingFields.push("Policy Number");
        }

        if (!issueCountry) {
            missingFields.push("Issue Country");
        }

        if (!policyClassification) {
            missingFields.push("Policy Classification");
        }

        if (
            !sourceSystem ||
            !allowedValues.includes(sourceSystem)
        ) {
            missingFields.push("Source Name");
        }

        if (missingFields.length > 0) {

            await parent.Xrm.Navigation.openAlertDialog({
                title: "Validation Error",
                text:
                    "Below fields are either empty or invalid.\n\n" +
                    missingFields.join("\n")
            });

            return false;
        }

        return true;
    }

    function mapSource(sourceName) {

        switch ((sourceName || "").trim()) {

            case "Ingenium":
            case "ING":
                return "ING";

            case "Life 70":
            case "L70":
                return "L70";

            case "LTC":
                return "LTC";

            case "DI":
                return "DI";

            default:
                return "ING";
        }
    }

    function mapCompanyCode(issueCountry) {

        const country =
            String(issueCountry || "")
                .trim()
                .toUpperCase();

        switch (country) {

            case "US":
            case "USA":
            case "UNITED STATES":
            case "258510000":
                return "01";

            case "CANADA":
            case "258510001":
                return "50";

            default:
                return "01";
        }
    }

    function mapClassification(policyClassification) {

        if (!policyClassification) {
            return "";
        }

        return policyClassification
            .toString()
            .trim();
    }

    function toggleSection(sectionId, visible) {

        const el = document.getElementById(sectionId);

        if (!el) {
            return;
        }

        if (visible) {
            el.classList.remove("hidden");
        } else {
            el.classList.add("hidden");
        }
    }

    function getSectionVisibility(sourceName, policyClassification) {

        const gblSourceSystem = mapSource(sourceName);
        const gblClassificationText = mapClassification(policyClassification);

        const ShowLifeIngContainer =
            gblSourceSystem === "ING" &&
            gblClassificationText === "Life";

        const ShowLifeL70Container =
            gblSourceSystem === "L70" &&
            gblClassificationText === "Life";

        const ShowAnnuityIngContainer =
            gblSourceSystem === "ING" &&
            gblClassificationText === "Annuity";

        const ShowAnnuityL70Container =
            gblSourceSystem === "L70" &&
            gblClassificationText === "Annuity";

        const ShowLTCContainer =
            gblClassificationText === "LTC";

        const ShowDIContainer =
            gblClassificationText === "DI";

        return {
            gblSourceSystem: gblSourceSystem,
            gblClassificationText: gblClassificationText,
            ShowLifeIngContainer: ShowLifeIngContainer,
            ShowLifeL70Container: ShowLifeL70Container,
            ShowAnnuityIngContainer: ShowAnnuityIngContainer,
            ShowAnnuityL70Container: ShowAnnuityL70Container,
            ShowLTCContainer: ShowLTCContainer,
            ShowDIContainer: ShowDIContainer
        };
    }

    function applySectionVisibility(sourceName, policyClassification) {

        const visibility = getSectionVisibility(
            sourceName,
            policyClassification
        );

        console.log("Section visibility:", visibility);

        const showLifeAnnuitySection =
            visibility.ShowLifeIngContainer ||
            visibility.ShowLifeL70Container ||
            visibility.ShowAnnuityIngContainer ||
            visibility.ShowAnnuityL70Container;

        toggleSection("lifeSection", showLifeAnnuitySection);
        toggleSection("DISection", visibility.ShowDIContainer);
        toggleSection("LTCSection", visibility.ShowLTCContainer);
    }

    async function fetchPolicyData(
        policyNo,
        sourceName,
        issueCountry,
        policyClassification
    ) {

        try {

            const source =
                mapSource(sourceName);

            const companyCode =
                mapCompanyCode(issueCountry);

            const classificationCode =
                mapClassification(policyClassification);

            const userName =
                parent.Xrm.Utility
                    .getGlobalContext()
                    .userSettings
                    .internalEmailAddress || "system";

            const url =
                `https://kofc-dev-nhtl1-fa-awahhfaebegzeqgz.eastus-01.azurewebsites.net/api/getPolicyData` +
                `?code=QiiGQtqB35Zuemtr2KFf4qrNaw9jbTHAv1eCPBZbgmeIAzFuhnip1Q==` +
                `&source=${encodeURIComponent(source)}` +
                `&companyCode=${encodeURIComponent(companyCode)}` +
                `&policyNo=${encodeURIComponent(policyNo)}` +
                `&userName=${encodeURIComponent(userName)}` +
                `&classificationCode=${encodeURIComponent(classificationCode)}`;

            console.log("API URL:", url);

            const response = await fetch(url);

            if (!response.ok) {
                throw new Error(
                    "API failed with status " +
                    response.status
                );
            }

            const data = await response.json();

            console.log("API Data:", data);

            return data;

        } catch (e) {

            console.error("API Error:", e);

            return null;
        }
    }

    function setValue(id, value) {

